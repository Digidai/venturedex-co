{
  "name": "venturedex",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && printf '_worker.js\n' > dist/.assetsignore",
    "preview": "astro preview",
    "astro": "astro",
    "test:newsletter": "tsx --test tests/*.test.ts",
    "db:migrate": "bash scripts/migrate-newsletter.sh --local && wrangler d1 execute venturedex-db --local --file=d1/schema.sql"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.5.0",
    "astro": "^5.7.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "better-sqlite3": "^12.10.0",
    "tsx": "^4.22.3",
    "typescript": "^5.8.0",
    "wrangler": "^4.14.0"
  }
}
