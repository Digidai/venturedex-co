# Long-lived caching for static media (served by Cloudflare Workers Assets).
# These rarely change; previously they revalidated on every page view (max-age=0).

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: frame-ancestors 'none'; object-src 'none'; base-uri 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com https://*.clarity.ms; connect-src 'self' https://cloudflareinsights.com https://*.clarity.ms https://c.bing.com; img-src 'self' data: https://*.clarity.ms https://c.bing.com

# Self-hosted fonts are immutable assets — cache for a year. Rename the file
# (not just replace contents) if a face ever changes, to bust the cache.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Static search index fetched by /search. Short browser TTL, long edge TTL with
# stale-while-revalidate so it refreshes after a deploy without a blocking fetch.
/search-index.json
  Cache-Control: public, max-age=300, s-maxage=86400, stale-while-revalidate=604800

/ai-index.json
  Cache-Control: public, max-age=300, s-maxage=86400, stale-while-revalidate=604800

/llms.txt
  Cache-Control: public, max-age=3600

/llms-full.txt
  Cache-Control: public, max-age=3600

/screenshots/*
  Cache-Control: public, max-age=604800

/logos/*
  Cache-Control: public, max-age=604800

/favicon.svg
  Cache-Control: public, max-age=604800

/og/*
  Cache-Control: public, max-age=604800

/og-image.png
  Cache-Control: public, max-age=604800
