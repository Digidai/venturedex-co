---
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = "A curated gallery of startups worth watching.", ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://venturedex.co");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | VentureDex</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="alternate" type="application/rss+xml" title="VentureDex" href="/feed.xml" />
    <script is:inline>
      (function(){var t;try{t=localStorage.getItem('venturedex-theme')}catch{}if(t&&t!=='auto'){document.documentElement.setAttribute('data-theme',t);document.documentElement.style.colorScheme=t}})();
    </script>
  </head>
  <body>
    <a href="#main" class="visually-hidden">Skip to main content</a>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="logo">VentureDex</a>
        <nav aria-label="Main navigation">
          <div class="nav-tabs">
            <a href="/" class="nav-tab">Explore</a>
            <a href="/collections" class="nav-tab">Collections</a>
            <a href="/weekly" class="nav-tab">Weekly</a>
            <a href="/funding" class="nav-tab">Funding</a>
          </div>
        </nav>
        <div class="header-actions">
          <a href="/search" class="header-search" aria-label="Search">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </a>
          <ThemeToggle />
          <a href="/subscribe" class="header-cta">Subscribe</a>
        </div>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <p class="footer-brand">VentureDex</p>
        <p class="footer-tagline">A curated gallery of startups worth watching.</p>
        <nav class="footer-links" aria-label="Footer navigation">
          <a href="/sponsor">Sponsor</a>
          <a href="/subscribe">Subscribe</a>
          <a href="/feed.xml">RSS</a>
        </nav>
      </div>
    </footer>

    <style>
      .site-header {
        border-bottom: 1px solid var(--color-border);
        padding: var(--space-4) 0;
      }

      .header-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .logo {
        font-family: var(--font-heading);
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--color-text);
        text-decoration: none;
      }

      .nav-tabs {
        display: flex;
        gap: 0;
        border: 1px solid var(--color-border);
        border-radius: 8px;
        overflow: hidden;
      }

      .nav-tab {
        padding: var(--space-2) var(--space-4);
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--color-text-secondary);
        text-decoration: none;
        transition: background 0.15s, color 0.15s;
        border-right: 1px solid var(--color-border);
      }

      .nav-tab:last-child {
        border-right: none;
      }

      .nav-tab:hover {
        background: var(--color-badge-bg);
        color: var(--color-text);
        text-decoration: none;
      }

      .header-actions {
        display: flex;
        align-items: center;
        gap: var(--space-3);
      }

      .header-search {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border-radius: 6px;
        color: var(--color-text-secondary);
        transition: color 0.15s, background 0.15s;
      }

      .header-search:hover {
        color: var(--color-text);
        background: var(--color-badge-bg);
      }

      .header-cta {
        font-size: 0.8rem;
        font-weight: 600;
        padding: var(--space-2) var(--space-4);
        background: var(--color-text);
        color: var(--color-bg);
        border-radius: 6px;
        text-decoration: none;
        transition: opacity 0.15s;
      }

      .header-cta:hover {
        opacity: 0.85;
        text-decoration: none;
      }

      .site-footer {
        border-top: 1px solid var(--color-border);
        padding: var(--space-12) 0;
        margin-top: var(--space-16);
      }

      .footer-inner {
        text-align: center;
      }

      .footer-brand {
        font-family: var(--font-heading);
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: var(--space-2);
      }

      .footer-tagline {
        color: var(--color-text-secondary);
        font-size: 0.875rem;
        margin-bottom: var(--space-6);
      }

      .footer-links {
        display: flex;
        justify-content: center;
        gap: var(--space-6);
      }

      .footer-links a {
        color: var(--color-text-secondary);
        font-size: 0.875rem;
      }

      @media (max-width: 640px) {
        .header-inner {
          flex-wrap: wrap;
          gap: var(--space-3);
        }

        .nav-tabs {
          order: 3;
          width: 100%;
          justify-content: center;
        }

        .nav-tab {
          flex: 1;
          text-align: center;
          font-size: 0.75rem;
        }

        .header-cta {
          font-size: 0.75rem;
        }
      }
    </style>
  </body>
</html>
