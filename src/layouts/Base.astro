---
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle.astro";
import {
  absoluteUrl,
  canonicalPath as normalizeCanonicalPath,
  DEFAULT_SITE_URL,
  SITE_NAME,
  toIsoDateTime,
  truncateText,
  type JsonLdNode,
} from "../lib/seo";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  ogImageType?: string;
  canonicalPath?: string;
  robots?: string;
  ogType?: string;
  publishedTime?: string | null;
  modifiedTime?: string | null;
  schema?: JsonLdNode | JsonLdNode[];
  alternateMarkdownPath?: string;
}

const {
  title,
  description = "A curated gallery of startups worth watching.",
  ogImage,
  ogImageWidth,
  ogImageHeight,
  ogImageType,
  canonicalPath,
  robots = "index,follow,max-image-preview:large",
  ogType = "website",
  publishedTime,
  modifiedTime,
  schema,
  alternateMarkdownPath,
} = Astro.props;

const siteUrl = Astro.site?.toString() ?? DEFAULT_SITE_URL;
const normalizedPath = normalizeCanonicalPath(canonicalPath ?? Astro.url.pathname);
const canonicalURL = absoluteUrl(normalizedPath, siteUrl);
const metaDescription = truncateText(description);
const pageTitle = `${title} | ${SITE_NAME}`;
const usesDefaultOgImage = !ogImage;
const ogImageUrl = absoluteUrl(ogImage ?? "/og-image.png", siteUrl);
const resolvedOgImageWidth = ogImageWidth ?? (usesDefaultOgImage ? 1200 : undefined);
const resolvedOgImageHeight = ogImageHeight ?? (usesDefaultOgImage ? 630 : undefined);
const ogImageAlt = `${title} on ${SITE_NAME}`;
const publishedIso = toIsoDateTime(publishedTime);
const modifiedIso = toIsoDateTime(modifiedTime);
const schemaItems = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
const pathname = normalizeCanonicalPath(Astro.url.pathname);
const navItems = [
  { href: "/", label: "Explore" },
  { href: "/startups", label: "Startups" },
  { href: "/investors", label: "Investors" },
  { href: "/news", label: "News" },
  { href: "/collections", label: "Collections" },
  { href: "/weekly", label: "Weekly" },
].map((item) => ({
  ...item,
  isActive: item.href === "/" ? pathname === "/" : pathname === item.href || pathname.startsWith(`${item.href}/`),
}));
const footerItems = [
  { href: "/startups", label: "Startups" },
  { href: "/investors", label: "Investors" },
  { href: "/about", label: "About" },
  { href: "/editorial-policy", label: "Editorial Policy" },
  { href: "/sponsor", label: "Sponsor" },
  { href: "/subscribe", label: "Subscribe" },
  { href: "/feed.xml", label: "RSS" },
].map((item) => ({
  ...item,
  isActive: item.href !== "/feed.xml" && pathname === item.href,
}));
const isSearchActive = pathname === "/search";
const isSubscribeActive = pathname === "/subscribe";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={metaDescription} />
    <meta name="robots" content={robots} />
    <meta name="application-name" content={SITE_NAME} />
    <meta name="theme-color" content="#FAFAF8" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0F0F0E" media="(prefers-color-scheme: dark)" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,700;1,400&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,400&family=JetBrains+Mono:wght@400&display=swap" />
    <link rel="canonical" href={canonicalURL} />
    {alternateMarkdownPath && (
      <link rel="alternate" type="text/markdown" title={`${title} Markdown`} href={absoluteUrl(alternateMarkdownPath, siteUrl)} />
    )}
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="en_US" />
    {ogType === "article" && publishedIso && <meta property="article:published_time" content={publishedIso} />}
    {ogType === "article" && modifiedIso && <meta property="article:modified_time" content={modifiedIso} />}
    <meta property="og:image" content={ogImageUrl} />
    {resolvedOgImageWidth && <meta property="og:image:width" content={String(resolvedOgImageWidth)} />}
    {resolvedOgImageHeight && <meta property="og:image:height" content={String(resolvedOgImageHeight)} />}
    {ogImageType && <meta property="og:image:type" content={ogImageType} />}
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title="VentureDex" href="/feed.xml" />
    {schemaItems.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
    <script is:inline>
      (function(){var t;try{t=localStorage.getItem('venturedex-theme')}catch{}if(t&&t!=='auto'){document.documentElement.setAttribute('data-theme',t);document.documentElement.style.colorScheme=t}})();
    </script>
  </head>
  <body>
    <a href="#main" class="visually-hidden">Skip to main content</a>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="logo">VentureDex</a>
        <nav class="main-nav" aria-label="Main navigation">
          <div class="nav-tabs">
            {navItems.map((item) => (
              <a
                href={item.href}
                class:list={["nav-tab", item.isActive && "nav-tab--active"]}
                aria-current={item.isActive ? "page" : undefined}
              >
                {item.label}
              </a>
            ))}
          </div>
        </nav>
        <div class="header-actions">
          <a
            href="/search"
            class:list={["header-search", isSearchActive && "header-search--active"]}
            aria-label="Search"
            aria-current={isSearchActive ? "page" : undefined}
          >
            <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </a>
          <ThemeToggle />
          <a
            href="/subscribe"
            class:list={["header-cta", isSubscribeActive && "header-cta--active"]}
            aria-current={isSubscribeActive ? "page" : undefined}
          >
            Subscribe
          </a>
        </div>
      </div>
    </header>

    <main id="main" tabindex="-1">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <p class="footer-brand">VentureDex</p>
        <p class="footer-tagline">A curated gallery of startups worth watching.</p>
        <nav class="footer-links" aria-label="Footer navigation">
          {footerItems.map((item) => (
            <a href={item.href} aria-current={item.isActive ? "page" : undefined}>{item.label}</a>
          ))}
        </nav>
      </div>
    </footer>

    <style>
      .site-header {
        border-bottom: 1px solid var(--color-border);
        padding: var(--space-4) 0;
      }

      .header-inner {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
        align-items: center;
        gap: var(--space-4);
        min-width: 0;
      }

      .logo {
        flex: 0 0 auto;
        justify-self: start;
        display: inline-flex;
        align-items: center;
        min-height: 44px;
        font-family: var(--font-heading);
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--color-text);
        text-decoration: none;
      }

      .main-nav {
        flex: 0 1 auto;
        justify-self: center;
        min-width: 0;
      }

      .nav-tabs {
        display: inline-flex;
        gap: 0;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        overflow: auto;
        overscroll-behavior-inline: contain;
        scrollbar-width: none;
        width: max-content;
        max-width: 100%;
        scroll-snap-type: inline proximity;
      }

      .nav-tabs::-webkit-scrollbar {
        display: none;
      }

      .nav-tab {
        display: inline-flex;
        align-items: center;
        min-height: 44px;
        padding: var(--space-2) var(--space-4);
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--color-text-secondary);
        text-decoration: none;
        transition: background 0.15s, color 0.15s;
        border-right: 1px solid var(--color-border);
        white-space: nowrap;
        scroll-snap-align: start;
      }

      .nav-tab:last-child {
        border-right: none;
      }

      .nav-tab:hover,
      .nav-tab--active {
        background: var(--color-badge-bg);
        color: var(--color-text);
        text-decoration: none;
      }

      .header-actions {
        justify-self: end;
        display: flex;
        align-items: center;
        gap: var(--space-3);
        flex: 0 0 auto;
        margin-left: 0;
      }

      .header-search {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        border-radius: var(--radius-md);
        color: var(--color-text-secondary);
        transition: color 0.15s, background 0.15s;
      }

      .header-search:hover,
      .header-search--active {
        color: var(--color-text);
        background: var(--color-badge-bg);
      }

      .header-cta {
        flex: 0 0 auto;
        display: inline-flex;
        align-items: center;
        min-height: 44px;
        font-size: 0.8rem;
        font-weight: 600;
        padding: var(--space-2) var(--space-4);
        background: var(--color-text);
        color: var(--color-bg);
        border-radius: var(--radius-md);
        text-decoration: none;
        transition: opacity 0.15s;
      }

      .header-cta:hover {
        opacity: 0.85;
        text-decoration: none;
      }

      .header-cta--active {
        opacity: 0.85;
      }

      .site-footer {
        border-top: 1px solid var(--color-border);
        padding: var(--space-12) 0;
        margin-top: var(--space-16);
      }

      .footer-inner {
        text-align: center;
      }

      .footer-brand {
        font-family: var(--font-heading);
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: var(--space-2);
      }

      .footer-tagline {
        color: var(--color-text-secondary);
        font-size: 0.875rem;
        margin-bottom: var(--space-6);
      }

      .footer-links {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: var(--space-3) var(--space-6);
      }

      .footer-links a {
        display: inline-flex;
        align-items: center;
        min-height: 44px;
        color: var(--color-text-secondary);
        font-size: 0.875rem;
        white-space: nowrap;
      }

      .footer-links a[aria-current="page"] {
        color: var(--color-text);
      }

      @media (max-width: 900px) {
        .header-inner {
          display: flex;
          flex-wrap: wrap;
        }

        .header-actions {
          margin-left: auto;
        }

        .main-nav {
          order: 3;
          width: 100%;
        }

        .nav-tabs {
          width: 100%;
        }

        .nav-tab {
          flex: 1 1 auto;
          justify-content: center;
        }
      }

      @media (max-width: 640px) {
        .header-inner {
          gap: var(--space-3);
        }

        .nav-tab {
          flex: 1 1 calc(33.333% - 1px);
          justify-content: center;
          text-align: center;
          font-size: 0.75rem;
          padding: var(--space-2) var(--space-3);
        }

        .nav-tabs {
          display: flex;
          flex-wrap: wrap;
          overflow: visible;
        }

        .nav-tab:nth-child(3n) {
          border-right: none;
        }

        .nav-tab:nth-child(-n + 3) {
          border-bottom: 1px solid var(--color-border);
        }

        .header-actions {
          gap: var(--space-2);
        }

        .header-cta {
          font-size: 0.75rem;
          padding-inline: var(--space-3);
        }

        .site-footer {
          padding: var(--space-8) 0;
          margin-top: var(--space-12);
        }

        .footer-links {
          gap: var(--space-2) var(--space-4);
        }
      }

      @media (max-width: 360px) {
        .header-inner {
          column-gap: var(--space-2);
        }

        .logo {
          font-size: 1.125rem;
        }

        .header-cta {
          padding-inline: var(--space-2);
        }

        .header-actions {
          width: 100%;
          justify-content: space-between;
          margin-left: 0;
        }
      }
    </style>
  </body>
</html>
