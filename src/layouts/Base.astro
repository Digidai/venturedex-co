---
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle.astro";
import {
  DEFAULT_SITE_URL,
  DEFAULT_SOCIAL_IMAGE,
  SITE_NAME,
  absoluteUrl,
  canonicalPath as normalizeCanonicalPath,
  toIsoDateTime,
  truncateText,
  type JsonLdNode,
} from "../lib/seo";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  ogImageType?: string;
  canonicalPath?: string;
  robots?: string;
  ogType?: string;
  publishedTime?: string | null;
  modifiedTime?: string | null;
  schema?: JsonLdNode | JsonLdNode[];
}

const {
  title,
  description = "A curated gallery of startups worth watching.",
  ogImage,
  ogImageWidth,
  ogImageHeight,
  ogImageType,
  canonicalPath,
  robots = "index,follow,max-image-preview:large",
  ogType = "website",
  publishedTime,
  modifiedTime,
  schema,
} = Astro.props;

const siteUrl = Astro.site?.toString() ?? DEFAULT_SITE_URL;
const canonicalURL = absoluteUrl(normalizeCanonicalPath(canonicalPath ?? Astro.url.pathname), siteUrl);
const metaDescription = truncateText(description);
const pageTitle = `${title} | ${SITE_NAME}`;
const usesDefaultOgImage = !ogImage;
const ogImageUrl = absoluteUrl(ogImage ?? DEFAULT_SOCIAL_IMAGE, siteUrl);
const resolvedOgImageWidth = ogImageWidth ?? (usesDefaultOgImage ? 1200 : undefined);
const resolvedOgImageHeight = ogImageHeight ?? (usesDefaultOgImage ? 630 : undefined);
const ogImageAlt = `${title} on ${SITE_NAME}`;
const publishedIso = toIsoDateTime(publishedTime);
const modifiedIso = toIsoDateTime(modifiedTime);
const schemaItems = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
// Escape "<" so values containing "</script>" cannot break out of the ld+json block.
const schemaJson = schemaItems.map((item) => JSON.stringify(item).split("<").join("\\u003c"));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={metaDescription} />
    <meta name="robots" content={robots} />
    <meta name="application-name" content={SITE_NAME} />
    <meta name="theme-color" content="#fafaf8" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0f0f0e" media="(prefers-color-scheme: dark)" />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="en_US" />
    {ogType === "article" && publishedIso && <meta property="article:published_time" content={publishedIso} />}
    {ogType === "article" && modifiedIso && <meta property="article:modified_time" content={modifiedIso} />}
    <meta property="og:image" content={ogImageUrl} />
    {resolvedOgImageWidth && <meta property="og:image:width" content={String(resolvedOgImageWidth)} />}
    {resolvedOgImageHeight && <meta property="og:image:height" content={String(resolvedOgImageHeight)} />}
    {ogImageType && <meta property="og:image:type" content={ogImageType} />}
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title="VentureDex" href="/feed.xml" />
    {schemaJson.map((json) => (
      <script type="application/ld+json" set:html={json} />
    ))}
    <script is:inline>
      (function(){var t;try{t=localStorage.getItem('venturedex-theme')}catch{}if(t&&t!=='auto'){document.documentElement.setAttribute('data-theme',t);document.documentElement.style.colorScheme=t}})();
    </script>
  </head>
  <body>
    <a href="#main" class="visually-hidden">Skip to main content</a>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="logo">VentureDex</a>
        <nav aria-label="Main navigation">
          <div class="nav-tabs">
            <a href="/" class="nav-tab">Explore</a>
            <a href="/collections" class="nav-tab">Collections</a>
            <a href="/weekly" class="nav-tab">Weekly</a>
            <a href="/investors" class="nav-tab">Investors</a>
            <a href="/news" class="nav-tab">News</a>
          </div>
        </nav>
        <div class="header-actions">
          <a href="/search" class="header-search" aria-label="Search">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </a>
          <ThemeToggle />
          <a href="/subscribe" class="header-cta">Subscribe</a>
        </div>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <p class="footer-brand">VentureDex</p>
        <p class="footer-tagline">A curated gallery of startups worth watching.</p>
        <nav class="footer-links" aria-label="Footer navigation">
          <a href="/about">About</a>
          <a href="/editorial-policy">Editorial Policy</a>
          <a href="/sponsor">Sponsor</a>
          <a href="/subscribe">Subscribe</a>
          <a href="/feed.xml">RSS</a>
        </nav>
        <p class="footer-credit">
          Crafted by <a href="https://genedai.md" target="_blank" rel="noopener noreferrer">Gene Dai</a>
        </p>
      </div>
    </footer>

    <style>
      .site-header {
        border-bottom: 1px solid var(--color-border);
        padding: var(--space-4) 0;
      }

      .header-inner {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr) auto;
        align-items: center;
        gap: var(--space-4);
      }

      .logo {
        font-family: var(--font-heading);
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--color-text);
        text-decoration: none;
        flex: 0 0 auto;
        justify-self: start;
      }

      .header-inner > nav {
        min-width: 0;
        justify-self: center;
        max-width: 100%;
      }

      .nav-tabs {
        display: flex;
        gap: 0;
        border: 1px solid var(--color-border);
        border-radius: 8px;
        overflow: hidden;
      }

      .nav-tab {
        padding: var(--space-2) var(--space-4);
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--color-text-secondary);
        text-decoration: none;
        transition: background 0.15s, color 0.15s;
        border-right: 1px solid var(--color-border);
      }

      .nav-tab:last-child {
        border-right: none;
      }

      .nav-tab:hover {
        background: var(--color-badge-bg);
        color: var(--color-text);
        text-decoration: none;
      }

      .header-actions {
        display: flex;
        align-items: center;
        gap: var(--space-3);
        flex: 0 0 auto;
        justify-self: end;
      }

      .header-search {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border-radius: 6px;
        color: var(--color-text-secondary);
        transition: color 0.15s, background 0.15s;
      }

      .header-search:hover {
        color: var(--color-text);
        background: var(--color-badge-bg);
      }

      .header-cta {
        font-size: 0.8rem;
        font-weight: 600;
        padding: var(--space-2) var(--space-4);
        background: var(--color-text);
        color: var(--color-bg);
        border-radius: 6px;
        text-decoration: none;
        transition: opacity 0.15s;
      }

      .header-cta:hover {
        opacity: 0.85;
        text-decoration: none;
      }

      .site-footer {
        border-top: 1px solid var(--color-border);
        padding: var(--space-12) 0;
        margin-top: var(--space-16);
      }

      .footer-inner {
        text-align: center;
      }

      .footer-brand {
        font-family: var(--font-heading);
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: var(--space-2);
      }

      .footer-tagline {
        color: var(--color-text-secondary);
        font-size: 0.875rem;
        margin-bottom: var(--space-6);
      }

      .footer-links {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: var(--space-6);
      }

      .footer-links a {
        color: var(--color-text-secondary);
        font-size: 0.875rem;
      }

      .footer-credit {
        margin-top: var(--space-6);
        font-size: 0.8125rem;
        color: var(--color-text-secondary);
      }

      .footer-credit a {
        color: var(--color-text);
        font-weight: 500;
        text-decoration: underline;
        text-underline-offset: 2px;
      }

      @media (max-width: 800px) {
        .header-inner {
          grid-template-columns: 1fr auto;
          gap: var(--space-3);
          align-items: center;
        }

        .header-inner > nav {
          grid-column: 1 / -1;
          grid-row: 2;
          width: 100%;
          min-width: 0;
          display: flex;
          justify-content: center;
          overflow-x: auto;
          -webkit-overflow-scrolling: touch;
          scrollbar-width: none;
        }

        .header-inner > nav::-webkit-scrollbar {
          display: none;
        }

        .nav-tabs {
          display: inline-flex;
          flex: 0 0 auto;
          width: max-content;
          max-width: 100%;
        }

        .nav-tab {
          flex: 0 0 auto;
          text-align: center;
          font-size: 0.75rem;
          padding: var(--space-2) var(--space-3);
        }

        .header-cta {
          font-size: 0.75rem;
        }
      }

      @media (max-width: 420px) {
        .header-inner {
          align-items: flex-start;
        }

        .header-inner > nav {
          justify-content: flex-start;
        }

        .nav-tabs {
          max-width: none;
        }

        .nav-tab {
          padding-inline: var(--space-2);
        }

        .header-actions {
          gap: var(--space-2);
        }

        .header-cta {
          padding-inline: var(--space-3);
        }
      }
    </style>
  </body>
</html>
