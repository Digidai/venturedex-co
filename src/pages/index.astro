---
export const prerender = true;

import Base from "../layouts/Base.astro";
import SiteCard from "../components/SiteCard.astro";
import FilterBar from "../components/FilterBar.astro";
import FundingTicker from "../components/FundingTicker.astro";
import {
  getContentStartups,
  getContentNewsEligibleFundingRounds,
} from "../lib/content";
import { homeJsonLd } from "../lib/seo";

// Prerendered at build time from version-controlled content (no per-request D1).
// Default order mirrors the old D1 "featured" sort (is_featured DESC, then
// published_at DESC); the client script re-sorts/filters in place on demand.
const startups = getContentStartups().sort((a, b) => {
  if (b.is_featured !== a.is_featured) return b.is_featured - a.is_featured;
  return (b.published_at ?? "").localeCompare(a.published_at ?? "");
});
const rounds = getContentNewsEligibleFundingRounds().slice(0, 32);

const startupCount = startups.length;
const countLabel = startupCount === 1 ? "company" : "companies";
const description =
  "Explore source-backed startup profiles with product evidence, funding signals, investor context, editorial notes, and canonical company links.";
const schema = homeJsonLd(startups, Astro.site?.toString());
---

<Base title="Curated Startup Directory" description={description} schema={schema}>
  <FundingTicker rounds={rounds} />

  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <h1>Discover startups worth tracking</h1>
        <p class="hero-sub">
          A thoughtful gallery of {startupCount > 0 ? startupCount : ""} outstanding early-stage companies.
          Profiles include product context, funding signals, investor links, and source-backed notes.
        </p>
      </div>
    </div>
  </section>

  <section class="explore">
    <div class="container">
      <FilterBar />

      {startups.length > 0 ? (
        <>
          <p class="result-count" data-result-count>{startupCount} {countLabel}</p>
          <div class="card-grid" data-card-grid data-total={startupCount}>
            <h2 class="visually-hidden">Startup profiles</h2>
            {startups.map((startup, position) => (
              <SiteCard
                startup={startup}
                priority={position < 3}
                index={{
                  name: startup.product_name,
                  type: startup.product_type,
                  stage: startup.funding_stage,
                  region: startup.region,
                  published: startup.published_at,
                  featured: startup.is_featured === 1,
                }}
              />
            ))}
          </div>
          <div class="empty-state" data-empty-state hidden>
            <h2>No matches.</h2>
            <p>Try adjusting your filters, or <button type="button" class="link-button" data-clear-inline>view all startups</button>.</p>
          </div>
        </>
      ) : (
        <div class="empty-state">
          <h2>Coming soon.</h2>
          <p>We're curating the first batch of startups. Subscribe to get notified.</p>
          <a href="/subscribe" class="cta-button">Get notified</a>
        </div>
      )}
    </div>
  </section>
</Base>

<script>
  // Client-side filtering/sorting over the prerendered card grid. Progressive
  // enhancement: with JS off, every card stays visible in the default (featured)
  // order and the filter panel never opens (its toggle is JS-only), so the page
  // degrades to a complete, browsable directory. The filter/sort semantics live
  // in src/lib/startup-filter.ts (unit-tested); this is just the DOM adapter.
  import {
    readFilterState,
    filterStateToQuery,
    cardMatchesFilters,
    orderVisibleCards,
    activeFacetCount,
    normalizeSort,
    type FilterableCard,
    type StartupFilterState,
  } from "../lib/startup-filter";

  // Typed DOM lookups. `@cloudflare/workers-types` is global (for the Worker), so
  // its DOM-lite shadows lib.dom inside client scripts; cast through `any` to get
  // the real browser element types back.
  const q = <T,>(sel: string, root: any = document): T | null => (root.querySelector(sel) as T) ?? null;
  const qa = <T,>(sel: string, root: any = document): T[] => Array.from(root.querySelectorAll(sel)) as T[];

  const grid = q<HTMLElement>("[data-card-grid]");
  if (grid) {
    type Entry = FilterableCard & { el: HTMLElement };
    let entries: Entry[] | null = null;
    const total = Number(grid.dataset.total ?? "0");

    function getEntries(): Entry[] {
      if (!entries) {
        entries = qa<HTMLElement>("[data-card]", grid).map((el) => ({
          el,
          name: el.dataset.name ?? "",
          type: el.dataset.type ?? null,
          stage: el.dataset.stage ?? null,
          region: el.dataset.region ?? null,
          published: el.dataset.published ?? null,
        }));
      }
      return entries;
    }

    const typeSel = q<HTMLSelectElement>("#filter-type");
    const stageSel = q<HTMLSelectElement>("#filter-stage");
    const regionSel = q<HTMLSelectElement>("#filter-region");
    const sortSel = q<HTMLSelectElement>("#filter-sort");
    const form = q<HTMLFormElement>(".filter-form");
    const clearBtn = q<HTMLElement>(".filter-clear");
    const countBadge = q<HTMLElement>(".filter-count");
    const resultCount = q<HTMLElement>("[data-result-count]");
    const emptyState = q<HTMLElement>("[data-empty-state]");
    const inlineClear = q<HTMLElement>("[data-clear-inline]");

    function readState(): StartupFilterState {
      return {
        type: (typeSel?.value ?? "").trim(),
        stage: (stageSel?.value ?? "").trim(),
        region: (regionSel?.value ?? "").trim(),
        sort: normalizeSort(sortSel?.value),
      };
    }

    function apply(updateUrl = true) {
      const state = readState();
      const entries = getEntries();
      for (const entry of entries) entry.el.hidden = !cardMatchesFilters(entry, state);
      const ordered = orderVisibleCards(entries, state);
      for (const entry of ordered) grid!.appendChild(entry.el);

      if (resultCount) {
        resultCount.textContent =
          ordered.length === total
            ? `${total} ${total === 1 ? "company" : "companies"}`
            : `${ordered.length} of ${total} companies`;
      }
      if (emptyState) emptyState.hidden = ordered.length !== 0;

      const facets = activeFacetCount(state);
      if (countBadge) {
        countBadge.textContent = String(facets);
        countBadge.hidden = facets === 0;
      }
      if (clearBtn) clearBtn.hidden = facets === 0;

      if (updateUrl) {
        const qs = filterStateToQuery(state);
        history.replaceState(null, "", qs ? `/?${qs}` : "/");
      }
    }

    function reset() {
      if (typeSel) typeSel.value = "";
      if (stageSel) stageSel.value = "";
      if (regionSel) regionSel.value = "";
      if (sortSel) sortSel.value = "featured";
      apply();
    }

    function hydrateFromUrl() {
      const state = readFilterState(new URLSearchParams(location.search));
      if (typeSel) typeSel.value = state.type;
      if (stageSel) stageSel.value = state.stage;
      if (regionSel) regionSel.value = state.region;
      if (sortSel) sortSel.value = state.sort;
    }

    [typeSel, stageSel, regionSel, sortSel].forEach((el) => el?.addEventListener("change", () => apply()));
    form?.addEventListener("submit", (e) => {
      e.preventDefault();
      apply();
    });
    clearBtn?.addEventListener("click", (e) => {
      e.preventDefault();
      reset();
    });
    inlineClear?.addEventListener("click", (e) => {
      e.preventDefault();
      reset();
    });

    const initialParams = new URLSearchParams(location.search);
    const hasActiveParams = Boolean(
      initialParams.get("type") ||
      initialParams.get("stage") ||
      initialParams.get("region") ||
      (initialParams.get("sort") && initialParams.get("sort") !== "featured")
    );
    if (hasActiveParams) {
      hydrateFromUrl();
      apply(false);
    }
  }
</script>

<style>
  .hero {
    padding: var(--space-8) 0;
    text-align: center;
    border-bottom: 1px solid var(--color-border);
  }

  .hero h1 {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    margin-bottom: var(--space-2);
  }

  .hero-sub {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.5;
  }

  .explore {
    padding: var(--space-8) 0 var(--space-16);
  }

  .result-count {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .empty-state {
    text-align: center;
    padding: var(--space-16) 0;
  }

  .empty-state h2 {
    font-size: 1.5rem;
    margin-bottom: var(--space-3);
  }

  .empty-state p {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
  }

  .link-button {
    background: none;
    border: none;
    padding: 0;
    font: inherit;
    color: var(--color-accent);
    cursor: pointer;
    text-decoration: underline;
  }

  .cta-button {
    display: inline-block;
    padding: var(--space-3) var(--space-6);
    background: var(--color-text);
    color: var(--color-bg);
    border-radius: var(--radius);
    font-weight: 500;
    font-size: 0.9rem;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .cta-button:hover {
    opacity: 0.85;
    text-decoration: none;
  }

  @media (max-width: 900px) {
    .card-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: var(--space-6) 0;
    }

    .card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
