---
export const prerender = false;

import Base from "../layouts/Base.astro";
import SiteCard from "../components/SiteCard.astro";
import FilterBar from "../components/FilterBar.astro";
import FundingTicker from "../components/FundingTicker.astro";
import {
  NEWS_ROUNDS_LIMIT,
  getNewsFundingRounds,
  getPublishedStartups,
  getStartupCount,
} from "../lib/db";
import { homeJsonLd } from "../lib/seo";
import type { SortOption } from "../lib/db";

const STARTUP_LIST_LIMIT = 500;
const db = Astro.locals.runtime.env.DB;

const productType = Astro.url.searchParams.get("type") ?? undefined;
const fundingStage = Astro.url.searchParams.get("stage") ?? undefined;
const region = Astro.url.searchParams.get("region") ?? undefined;
const sortRaw = Astro.url.searchParams.get("sort") ?? "featured";
const sort = (["featured", "newest", "name-az"].includes(sortRaw) ? sortRaw : "featured") as SortOption;

let startups: import("../lib/types").Startup[] = [];
let rounds: import("../lib/types").FundingRound[] = [];
let startupCount = 0;
let matchingStartupCount = 0;

try {
  [startups, startupCount, matchingStartupCount, rounds] = await Promise.all([
    getPublishedStartups(db, { productType, fundingStage, region, sort, limit: STARTUP_LIST_LIMIT }),
    getStartupCount(db),
    getStartupCount(db, { productType, fundingStage, region }),
    getNewsFundingRounds(db, NEWS_ROUNDS_LIMIT),
  ]);
} catch (error) {
  console.error("Failed to load homepage data", error);
}

const hasFacetFilters = !!(productType || fundingStage || region);
const hasActiveControls = hasFacetFilters || sort !== "featured";
const featured = startups.filter((s) => s.is_featured);
const rest = startups.filter((s) => !s.is_featured);
const featuredPreview = !hasActiveControls ? featured.slice(0, 3) : [];
const visibleStartups = hasActiveControls ? startups : [...featured.slice(3), ...rest];
const targetStartupCount = hasFacetFilters ? matchingStartupCount : startupCount;
const isTruncated = targetStartupCount > startups.length;
const heroCountText = hasFacetFilters
  ? isTruncated
    ? `Showing first ${startups.length} of ${targetStartupCount} matching early-stage companies.`
    : `Showing ${matchingStartupCount} of ${startupCount} outstanding early-stage companies.`
  : isTruncated
    ? `Showing first ${startups.length} of ${startupCount} outstanding early-stage companies.`
    : `A thoughtful gallery of ${startupCount > 0 ? startupCount : ''} outstanding early-stage companies.`;
const description = "A curated gallery of startups worth watching. Hand-picked with editorial commentary.";
const schema = homeJsonLd(startups, Astro.site?.toString());
---

<Base title="Explore" description={description} schema={schema}>
  <FundingTicker rounds={rounds} />

  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <h1>Discover today's top startups</h1>
        <p class="hero-sub">
          {heroCountText}
          Curated with editorial commentary.
        </p>
      </div>
    </div>
  </section>

  <section class="explore">
    <div class="container">
      <FilterBar
        currentType={productType}
        currentStage={fundingStage}
        currentRegion={region}
        currentSort={sort}
      />

      {startups.length > 0 ? (
        <>
          {featuredPreview.length > 0 && (
            <>
              <div class="section-label">Featured</div>
              <div class="featured-grid">
                {featuredPreview.map((startup) => (
                  <SiteCard startup={startup} size="large" />
                ))}
              </div>
              {visibleStartups.length > 0 && <div class="section-label">All startups</div>}
            </>
          )}
          <div class="card-grid">
            {visibleStartups.map((startup) => (
              <SiteCard startup={startup} />
            ))}
          </div>
        </>
      ) : hasActiveControls ? (
        <div class="empty-state">
          <h2>No matches.</h2>
          <p>Try adjusting your filters, or <a href="/">view all startups</a>.</p>
        </div>
      ) : (
        <div class="empty-state">
          <h2>Coming soon.</h2>
          <p>We're curating the first batch of startups. Subscribe to get notified.</p>
          <a href="/subscribe" class="cta-button">Get notified</a>
        </div>
      )}
    </div>
  </section>
</Base>

<style>
  .hero {
    padding: var(--space-8) 0;
    text-align: center;
    border-bottom: 1px solid var(--color-border);
  }

  .hero h1 {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    margin-bottom: var(--space-2);
  }

  .hero-sub {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.5;
  }

  .explore {
    padding: var(--space-8) 0 var(--space-16);
  }

  .section-label {
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    margin-bottom: var(--space-8);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .empty-state {
    text-align: center;
    padding: var(--space-16) 0;
  }

  .empty-state h2 {
    font-size: 1.5rem;
    margin-bottom: var(--space-3);
  }

  .empty-state p {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
  }

  .cta-button {
    display: inline-block;
    padding: var(--space-3) var(--space-6);
    background: var(--color-text);
    color: var(--color-bg);
    border-radius: var(--radius);
    font-weight: 500;
    font-size: 0.9rem;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .cta-button:hover {
    opacity: 0.85;
    text-decoration: none;
  }

  @media (max-width: 900px) {
    .featured-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .card-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: var(--space-6) 0;
    }

    .featured-grid {
      grid-template-columns: 1fr;
    }

    .card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
