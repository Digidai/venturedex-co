---
export const prerender = true;

import Base from "../../layouts/Base.astro";
import SiteCard from "../../components/SiteCard.astro";
import { getContentStartups } from "../../lib/content";
import { expandSeoDescription, topicPageJsonLd } from "../../lib/seo";
import { getTopicPageBySlug, getTopicPages } from "../../lib/topic-pages";
import { getPublishedWeeklyIssuesFromContent } from "../../lib/weekly";

export function getStaticPaths() {
  return getTopicPages(getContentStartups(), getPublishedWeeklyIssuesFromContent(Infinity))
    .map((topic) => ({ params: { slug: topic.slug } }));
}

const allStartups = getContentStartups();
const weeklyIssues = getPublishedWeeklyIssuesFromContent(Infinity);
const topic = getTopicPageBySlug(Astro.params.slug!, allStartups, weeklyIssues)!;
const description = expandSeoDescription(topic.description, topic.searchIntent, `${topic.title} on VentureDex.`);
const schema = topicPageJsonLd(topic, Astro.site?.toString());
const subscribeUrl = `/subscribe?source=${encodeURIComponent(`topic:${topic.slug}`)}`;

function formatDate(value: string | null | undefined) {
  if (!value) return "";
  return new Date(value).toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  });
}
---

<Base title={topic.title} description={description} schema={schema}>
  <div class="container topic-detail">
    <header>
      <a class="back-link" href="/topics">&larr; All topics</a>
      <p class="eyebrow">{topic.kicker}</p>
      <h1>{topic.title}</h1>
      <p class="description">{topic.description}</p>
    </header>

    <section class="topic-summary" aria-label="Topic summary">
      <div>
        <h2>What this topic tracks</h2>
        <p>{topic.intro}</p>
        <p>{topic.searchIntent}</p>
      </div>
      <dl>
        <div>
          <dt>Profiles</dt>
          <dd>{topic.startups.length}</dd>
        </div>
        {topic.latestStartups[0]?.published_at && (
          <div>
            <dt>Latest signal</dt>
            <dd>{formatDate(topic.latestStartups[0].published_at)}</dd>
          </div>
        )}
        {topic.topInvestors[0] && (
          <div>
            <dt>Frequent investor</dt>
            <dd>{topic.topInvestors[0].term}</dd>
          </div>
        )}
      </dl>
    </section>

    <section class="evidence-section" aria-label="Topic evidence">
      <div>
        <h2>Topic evidence</h2>
        <div class="term-list">
          {topic.generatedFrom.productTypes.map((term) => <span>{term}</span>)}
          {topic.generatedFrom.tags.map((term) => <span>{term}</span>)}
        </div>
      </div>
      {topic.fundingStages.length > 0 && (
        <div>
          <h2>Funding stages</h2>
          <div class="term-list">
            {topic.fundingStages.map((stage) => (
              <span>{stage.term}<small>{stage.count}</small></span>
            ))}
          </div>
        </div>
      )}
      {topic.topTags.length > 0 && (
        <div>
          <h2>Common tags</h2>
          <div class="term-list">
            {topic.topTags.map((tag) => (
              <a href={`/search?q=${encodeURIComponent(tag.term)}`}>{tag.term}<small>{tag.count}</small></a>
            ))}
          </div>
        </div>
      )}
      {topic.topInvestors.length > 0 && (
        <div>
          <h2>Frequent investors</h2>
          <div class="term-list">
            {topic.topInvestors.map((investor) => (
              <span>{investor.term}<small>{investor.count}</small></span>
            ))}
          </div>
        </div>
      )}
    </section>

    {topic.latestStartups.length > 0 && (
      <section class="latest-section" aria-label="Latest profiles">
        <div class="section-heading">
          <h2>Latest profiles</h2>
          <a href={subscribeUrl}>Get weekly research</a>
        </div>
        <div class="signal-grid">
          {topic.latestStartups.map((startup) => (
            <article>
              <p>{formatDate(startup.published_at)}</p>
              <h3><a href={`/startups/${startup.slug}`}>{startup.product_name}</a></h3>
              {startup.why_featured && <span>{startup.why_featured}</span>}
            </article>
          ))}
        </div>
      </section>
    )}

    {topic.relatedIssues.length > 0 && (
      <section class="weekly-section" aria-label="Related weekly research">
        <h2>Related weekly research</h2>
        <div class="weekly-list">
          {topic.relatedIssues.map(({ issue, matchingPickSlugs }) => (
            <a href={`/weekly/${issue.issue_number}`}>
              <span>Weekly #{issue.issue_number}</span>
              <strong>{issue.title}</strong>
              <small>{matchingPickSlugs.length} matching {matchingPickSlugs.length === 1 ? "pick" : "picks"}</small>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="profile-section" aria-label="Startup profiles">
      <h2>All {topic.title.toLowerCase()}</h2>
      <div class="card-grid">
        {topic.startups.map((startup) => <SiteCard startup={startup} />)}
      </div>
    </section>
  </div>
</Base>

<style>
  .topic-detail {
    max-width: 1200px;
    padding: var(--space-12) var(--space-6) var(--space-16);
  }

  .back-link {
    display: inline-block;
    margin-bottom: var(--space-4);
    color: var(--color-text-secondary);
    font-size: 0.85rem;
  }

  .eyebrow {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    margin-bottom: var(--space-2);
    text-transform: uppercase;
  }

  header h1 {
    max-width: 820px;
    font-size: clamp(2rem, 5vw, 3.6rem);
    margin-bottom: var(--space-4);
  }

  .description {
    max-width: 720px;
    color: var(--color-text-secondary);
    font-size: 1.02rem;
    line-height: 1.7;
  }

  .topic-summary {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: var(--space-8);
    margin: var(--space-10) 0;
    padding: var(--space-8) 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .topic-summary h2,
  .evidence-section h2,
  .latest-section h2,
  .weekly-section h2,
  .profile-section h2 {
    font-size: 1.1rem;
    margin-bottom: var(--space-4);
  }

  .topic-summary p {
    max-width: 760px;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .topic-summary p + p {
    margin-top: var(--space-3);
  }

  .topic-summary dl {
    display: grid;
    gap: var(--space-4);
  }

  .topic-summary dl div {
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }

  .topic-summary dt {
    color: var(--color-text-secondary);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .topic-summary dd {
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.4;
  }

  .evidence-section {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-8) var(--space-12);
    margin-bottom: var(--space-10);
  }

  .term-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .term-list a,
  .term-list span {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 6px 10px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg-card);
    color: var(--color-text);
    font-size: 0.82rem;
    text-decoration: none;
  }

  .term-list a:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    text-decoration: none;
  }

  .term-list small {
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .latest-section,
  .weekly-section {
    margin-bottom: var(--space-10);
    padding-bottom: var(--space-10);
    border-bottom: 1px solid var(--color-border);
  }

  .section-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .section-heading h2 {
    margin-bottom: 0;
  }

  .section-heading a {
    font-size: 0.85rem;
    font-weight: 600;
  }

  .signal-grid,
  .weekly-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .signal-grid article {
    min-width: 0;
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
  }

  .signal-grid p {
    margin-bottom: var(--space-2);
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .signal-grid h3 {
    font-size: 1rem;
    margin-bottom: var(--space-2);
  }

  .signal-grid h3 a {
    color: inherit;
  }

  .signal-grid span {
    display: block;
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    line-height: 1.5;
  }

  .weekly-list a {
    display: grid;
    gap: var(--space-2);
    min-width: 0;
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    color: var(--color-text);
    text-decoration: none;
  }

  .weekly-list a:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    text-decoration: none;
  }

  .weekly-list span,
  .weekly-list small {
    color: var(--color-text-secondary);
    font-size: 0.78rem;
  }

  .profile-section h2 {
    margin-bottom: var(--space-6);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-6);
  }

  @media (max-width: 900px) {
    .topic-summary,
    .evidence-section,
    .signal-grid,
    .weekly-list {
      grid-template-columns: 1fr;
    }

    .card-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .topic-detail {
      padding: var(--space-8) var(--space-4) var(--space-12);
    }

    .card-grid {
      grid-template-columns: 1fr;
    }

    .section-heading {
      align-items: flex-start;
      flex-direction: column;
      gap: var(--space-2);
    }
  }
</style>
