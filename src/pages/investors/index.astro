---
export const prerender = true;

import BrandLogo from "../../components/BrandLogo.astro";
import Base from "../../layouts/Base.astro";
import { getInvestorBrandAsset, resolveInvestorSlugByName } from "../../lib/brand-assets";
import { getContentInvestors, getContentNewsEligibleFundingRounds } from "../../lib/content";
import {
  buildJsonLdGraph,
  itemListNode,
  siteOrganization,
  siteWebSite,
  webPageNode,
} from "../../lib/seo";
import type { Investor } from "../../lib/types";

interface InvestorIndexRow extends Investor {
  round_count: number;
  last_round_at: string | null;
}

const allInvestors = getContentInvestors();
const rounds = getContentNewsEligibleFundingRounds();

// Aggregate round counts and most-recent date per investor slug using the
// canonical resolver (matches the rounds shown on each investor page).
const stats = new Map<string, { count: number; lastRoundAt: string | null }>();
for (const round of rounds) {
  const slug = resolveInvestorSlugByName(round.lead_investor);
  if (!slug) continue;
  const entry = stats.get(slug) ?? { count: 0, lastRoundAt: null };
  entry.count += 1;
  if (round.date && (!entry.lastRoundAt || round.date > entry.lastRoundAt)) {
    entry.lastRoundAt = round.date;
  }
  stats.set(slug, entry);
}

const investors: InvestorIndexRow[] = allInvestors
  .map((investor) => {
    const entry = stats.get(investor.slug);
    return {
      ...investor,
      round_count: entry?.count ?? 0,
      last_round_at: entry?.lastRoundAt ?? null,
    };
  })
  .filter((investor) => investor.round_count > 0)
  .sort((a, b) => {
    if (b.round_count !== a.round_count) return b.round_count - a.round_count;
    const aDate = a.last_round_at ?? "";
    const bDate = b.last_round_at ?? "";
    if (bDate !== aDate) return bDate.localeCompare(aDate);
    return a.name.localeCompare(b.name);
  });

const description = "Browse startup investors with VentureDex-tracked funding activity, portfolio company links, and source-backed market context.";
const schema = buildJsonLdGraph([
  siteOrganization(Astro.site?.toString()),
  siteWebSite(Astro.site?.toString()),
  webPageNode({
    path: "/investors",
    title: "Investors",
    description,
    type: "CollectionPage",
    siteUrl: Astro.site?.toString(),
  }),
  itemListNode(
    investors.map((investor) => ({
      name: investor.name,
      path: `/investors/${investor.slug}`,
      description: investor.description,
    })),
    Astro.site?.toString()
  ),
]);
---

<Base title="Startup Investors and Funding Activity" description={description} schema={schema}>
  <div class="container investors-page">
    <header class="page-header">
      <h1>Investors</h1>
      <p>{description}</p>
    </header>

    {investors.length > 0 ? (
      <div class="investor-grid">
        {investors.map((investor) => {
          const brand = getInvestorBrandAsset(investor.slug);
          return (
            <a href={`/investors/${investor.slug}`} class="investor-card">
              <div class="card-top">
                <BrandLogo asset={brand} name={investor.name} size={32} />
                <div class="card-copy">
                  <h2>{investor.name}</h2>
                  {investor.short_name && <p class="short-name">{investor.short_name}</p>}
                </div>
              </div>
              {investor.description && <p class="description">{investor.description}</p>}
              <p class="meta">
                {investor.round_count} tracked round{investor.round_count !== 1 ? "s" : ""}
                {investor.last_round_at && ` · Latest ${new Date(`${investor.last_round_at}T00:00:00`).toLocaleDateString("en-US", {
                  month: "short",
                  day: "numeric",
                  year: "numeric",
                })}`}
              </p>
            </a>
          );
        })}
      </div>
    ) : (
      <div class="empty-state">
        <h2>No tracked investors yet.</h2>
        <p>Investor pages appear after a published startup has verified funding activity.</p>
      </div>
    )}
  </div>
</Base>

<style>
  .investors-page {
    max-width: 1200px;
    padding-block: var(--space-12) var(--space-16);
  }

  .page-header {
    margin-bottom: var(--space-8);
  }

  .page-header h1 {
    font-size: 2rem;
    margin-bottom: var(--space-2);
  }

  .page-header p {
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-width: 640px;
  }

  .investor-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
    align-items: stretch;
  }

  .investor-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 188px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-6);
    background: var(--color-bg-card);
    color: inherit;
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }

  .investor-card:hover {
    border-color: var(--color-accent);
    background: var(--color-badge-bg);
    text-decoration: none;
  }

  .card-top {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .card-copy {
    min-width: 0;
  }

  .card-top h2 {
    font-size: 1rem;
    line-height: 1.2;
    margin-bottom: var(--space-1);
    overflow-wrap: anywhere;
  }

  .short-name,
  .description,
  .meta {
    color: var(--color-text-secondary);
  }

  .short-name {
    font-size: 0.8rem;
  }

  .description {
    font-size: 0.9rem;
    line-height: 1.5;
    margin-bottom: var(--space-4);
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .meta {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    margin-top: auto;
    padding-top: var(--space-1);
  }

  .empty-state {
    text-align: center;
    padding: var(--space-12) 0;
  }

  .empty-state h2 {
    font-size: 1.5rem;
    margin-bottom: var(--space-3);
  }

  .empty-state p {
    color: var(--color-text-secondary);
  }

  @media (max-width: 720px) {
    .investor-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
