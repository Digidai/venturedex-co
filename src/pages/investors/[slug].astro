---
export const prerender = false;

import Base from "../../layouts/Base.astro";
import BrandLogo from "../../components/BrandLogo.astro";
import {
  getCompanyBrandAsset,
  getInvestorBrandAsset,
} from "../../lib/brand-assets";
import { getInvestorBySlug } from "../../lib/db";
import { investorJsonLd, truncateText } from "../../lib/seo";

const { slug } = Astro.params;
const db = Astro.locals.runtime.env.DB;

const data = await getInvestorBySlug(db, slug!);
if (!data) return Astro.redirect("/404");

const { investor, rounds } = data;
const investorBrand = getInvestorBrandAsset(investor.slug);
const description = truncateText(investor.description ?? `${investor.name} portfolio on VentureDex`);
const schema = investorJsonLd(investor, rounds, Astro.site?.toString());
---

<Base
  title={investor.name}
  description={description}
  schema={schema}
  alternateMarkdownPath={`/investors/${investor.slug}.md`}
>
  <div class="container investor-page">
    <a href="/investors" class="back-link">&larr; Back to investors</a>

    <header class="investor-header">
      <div class="investor-identity">
        <BrandLogo asset={investorBrand} name={investor.name} size={40} loading="eager" class="investor-logo" />
        <div>
          <h1>{investor.name}</h1>
          {investor.website && (
            <a href={investor.website} target="_blank" rel="noopener noreferrer" class="investor-url">
              {new URL(investor.website).hostname} &nearr;
            </a>
          )}
        </div>
      </div>
      {investor.description && <p class="investor-desc">{investor.description}</p>}
    </header>

    <section class="portfolio">
      <h2>Portfolio on VentureDex <span class="count">({rounds.length})</span></h2>

      {rounds.length > 0 ? (
        <div class="portfolio-table-wrap">
          <table class="portfolio-table">
            <thead>
              <tr>
                <th>Company</th>
                <th>Round</th>
                <th>Date</th>
                <th>Source</th>
              </tr>
            </thead>
            <tbody>
              {rounds.map((r) => {
                const companyBrand = getCompanyBrandAsset(r.company_slug);
                return (
                  <tr>
                    <td class="cell-company">
                      <div class="company-info">
                        <BrandLogo asset={companyBrand} name={r.company_name} size={24} class="company-logo" />
                        <div>
                          {r.company_slug ? (
                            <a href={`/startups/${r.company_slug}`} class="company-link">{r.company_name}</a>
                          ) : (
                            <span>{r.company_name}</span>
                          )}
                        </div>
                      </div>
                    </td>
                    <td class="cell-round">
                      {r.amount && <span class="round-amount">{r.amount}</span>}
                      <span class="round-stage">· {r.stage}</span>
                    </td>
                    <td class="cell-date">
                      {new Date(r.date + "T00:00:00").toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
                    </td>
                    <td class="cell-source">
                      <a href={r.source_url!} target="_blank" rel="noopener noreferrer" class="source-link">
                        {r.source_name || "Press"} &nearr;
                      </a>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      ) : (
        <p class="empty">No investments tracked yet.</p>
      )}
    </section>
  </div>
</Base>

<style>
  .investor-page {
    max-width: 900px;
    padding: var(--space-12) var(--space-6) var(--space-16);
  }

  .back-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    display: inline-block;
    margin-bottom: var(--space-6);
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .investor-header {
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .investor-identity {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-3);
  }

  .investor-header h1 {
    font-size: 1.75rem;
    margin-bottom: var(--space-1);
  }

  .investor-url {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .investor-url:hover {
    color: var(--color-accent);
  }

  .investor-desc {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
    max-width: 600px;
  }

  .portfolio h2 {
    font-size: 1.1rem;
    margin-bottom: var(--space-6);
  }

  .count {
    font-weight: 400;
    color: var(--color-text-secondary);
  }

  .portfolio-table-wrap {
    overflow-x: auto;
  }

  .portfolio-table {
    width: 100%;
    border-collapse: collapse;
  }

  .portfolio-table thead th {
    text-align: left;
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-secondary);
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .portfolio-table tbody tr {
    border-bottom: 1px solid var(--color-border);
    transition: background 0.1s;
  }

  .portfolio-table tbody tr:hover {
    background: var(--color-badge-bg);
  }

  .portfolio-table td {
    padding: var(--space-4);
    font-size: 0.85rem;
    vertical-align: middle;
  }

  .cell-company {
    font-weight: 600;
  }

  .company-info {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .company-link {
    color: var(--color-text);
    text-decoration: none;
  }

  .company-link:hover {
    color: var(--color-accent);
  }

  .round-amount {
    color: var(--color-accent);
    font-weight: 600;
  }

  .round-stage {
    color: var(--color-text-secondary);
  }

  .cell-date {
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  .source-link {
    color: var(--color-text-secondary);
    font-size: 0.8rem;
    text-decoration: none;
  }

  .source-link:hover {
    color: var(--color-accent);
  }

  .empty {
    color: var(--color-text-secondary);
    padding: var(--space-8) 0;
  }
</style>
