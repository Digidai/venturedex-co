---
export const prerender = false;

import Base from "../../layouts/Base.astro";
import SiteCard from "../../components/SiteCard.astro";
import { getWeeklyIssueByNumber } from "../../lib/db";
import { normalizeExternalUrl, truncateText, weeklyIssueJsonLd } from "../../lib/seo";

const rawIssue = Astro.params.issue ?? "";
if (!/^[1-9]\d*$/.test(rawIssue)) {
  return new Response("Not found", {
    status: 404,
    headers: { "Content-Type": "text/plain; charset=utf-8" },
  });
}
const issueNum = Number(rawIssue);

const db = Astro.locals.runtime.env.DB;
const data = await getWeeklyIssueByNumber(db, issueNum);
if (!data) {
  return new Response("Not found", {
    status: 404,
    headers: { "Content-Type": "text/plain; charset=utf-8" },
  });
}

const { issue, startups } = data;
if (rawIssue !== String(issue.issue_number)) {
  return Astro.redirect(`/weekly/${issue.issue_number}`, 301);
}
const description = truncateText(issue.editorial_intro ?? `VentureDex Weekly #${issue.issue_number}`);
const schema = weeklyIssueJsonLd(issue, startups, Astro.site?.toString());
const antiPickUrl = normalizeExternalUrl(issue.anti_pick_url);
---

<Base
  title={issue.title}
  description={description}
  canonicalPath={`/weekly/${issue.issue_number}`}
  ogType="article"
  publishedTime={issue.published_at}
  schema={schema}
>
  <div class="container weekly-detail">
    <header class="issue-header">
      <a href="/weekly" class="back-link">&larr; All issues</a>
      <p class="issue-label">Weekly #{issue.issue_number}</p>
      <h1>{issue.title}</h1>
      {issue.published_at && (
        <time class="issue-date">
          {new Date(issue.published_at).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
        </time>
      )}
    </header>

    {issue.editorial_intro && (
      <div class="editorial-intro">
        <p>{issue.editorial_intro}</p>
      </div>
    )}

    <section class="picks">
      <h2>This week's picks</h2>
      {startups.length > 0 ? (
        <div class="picks-grid">
          {startups.map((startup) => (
            <SiteCard startup={startup} />
          ))}
        </div>
      ) : (
        <p class="picks-empty">No startups in this issue yet.</p>
      )}
    </section>

    {issue.anti_pick_name && (
      <section class="anti-pick">
        <h2>The Anti-Pick</h2>
        <div class="anti-pick-card">
          <p class="anti-pick-name">
            {antiPickUrl ? (
              <a href={antiPickUrl} target="_blank" rel="noopener noreferrer">
                {issue.anti_pick_name}
              </a>
            ) : issue.anti_pick_name}
          </p>
          {issue.anti_pick_reason && <p class="anti-pick-reason">{issue.anti_pick_reason}</p>}
        </div>
      </section>
    )}
  </div>
</Base>

<style>
  .weekly-detail {
    max-width: 900px;
    padding-block: var(--space-8) var(--space-16);
  }

  .back-link {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    margin-bottom: var(--space-4);
  }

  .issue-label {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-accent);
    margin-bottom: var(--space-2);
  }

  .issue-header h1 {
    font-size: 2rem;
    margin-bottom: var(--space-2);
  }

  .issue-date {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  .editorial-intro {
    margin: var(--space-8) 0;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    max-width: 650px;
  }

  .picks h2 {
    font-size: 1.25rem;
    margin-bottom: var(--space-6);
  }

  .picks-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }

  .picks-grid > * {
    min-width: 0;
  }

  @media (max-width: 640px) {
    .picks-grid {
      grid-template-columns: 1fr;
    }
  }

  .anti-pick {
    margin-top: var(--space-12);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-8);
  }

  .anti-pick h2 {
    font-size: 1.25rem;
    margin-bottom: var(--space-4);
  }

  .anti-pick-card {
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-danger);
    padding: var(--space-4) var(--space-6);
    border-radius: 0 var(--radius) var(--radius) 0;
    overflow-wrap: anywhere;
  }

  .anti-pick-name {
    font-weight: 600;
    margin-bottom: var(--space-2);
  }

  .anti-pick-reason {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .picks-empty {
    color: var(--color-text-secondary);
  }
</style>
