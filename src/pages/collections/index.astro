---
export const prerender = true;

import Base from "../../layouts/Base.astro";
import { getContentCollections } from "../../lib/content";
import {
  buildJsonLdGraph,
  itemListNode,
  siteOrganization,
  siteWebSite,
  webPageNode,
} from "../../lib/seo";

const collections = getContentCollections();

const description = "Browse curated VentureDex startup collections grouped by product category, market theme, and editorial context.";
const schema = buildJsonLdGraph([
  siteOrganization(Astro.site?.toString()),
  siteWebSite(Astro.site?.toString()),
  webPageNode({
    path: "/collections",
    title: "Collections",
    description,
    type: "CollectionPage",
    siteUrl: Astro.site?.toString(),
  }),
  itemListNode(
    collections.map((collection) => ({
      name: collection.title,
      path: `/collections/${collection.slug}`,
      description: collection.description,
    })),
    Astro.site?.toString()
  ),
]);
---

<Base title="Startup Collections" description={description} schema={schema}>
  <div class="container collections-page">
    <h1>Collections</h1>
    <p class="subtitle">Curated editorial groupings of VentureDex startups.</p>

    {collections.length > 0 ? (
      <div class="collections-grid">
        {collections.map((c) => (
          <a href={`/collections/${c.slug}`} class="collection-card">
            <h2>{c.title}</h2>
            {c.description && <p>{c.description}</p>}
            <span class="collection-count">{c.startup_count} startup{c.startup_count !== 1 ? 's' : ''}</span>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <h2>Collections coming soon.</h2>
        <p>We're building curated groupings of the best startups by category.</p>
      </div>
    )}
  </div>
</Base>

<style>
  .collections-page {
    max-width: 900px;
    padding: var(--space-12) var(--space-6) var(--space-16);
  }

  .collections-page > h1 {
    font-size: 2rem;
    margin-bottom: var(--space-2);
  }

  .subtitle {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
  }

  .collections-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-4);
  }

  .collection-card {
    display: block;
    padding: var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s;
  }

  .collection-card:hover {
    border-color: var(--color-accent);
    text-decoration: none;
  }

  .collection-card h2 {
    font-size: 1.1rem;
    margin-bottom: var(--space-2);
  }

  .collection-card p {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    line-height: 1.4;
  }

  .collection-count {
    display: block;
    margin-top: var(--space-3);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-secondary);
  }

  .empty-state {
    text-align: center;
    padding: var(--space-16) 0;
  }

  .empty-state h2 {
    font-size: 1.5rem;
    margin-bottom: var(--space-3);
  }

  .empty-state p {
    color: var(--color-text-secondary);
  }
</style>
