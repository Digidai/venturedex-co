---
export const prerender = false;

import Base from "../../layouts/Base.astro";
import { getPublishedCollections } from "../../lib/db";
import {
  buildJsonLdGraph,
  itemListNode,
  siteOrganization,
  siteWebSite,
  webPageNode,
} from "../../lib/seo";

const db = Astro.locals.runtime.env.DB;
let collections: Awaited<ReturnType<typeof getPublishedCollections>> = [];

try {
  collections = await getPublishedCollections(db);
} catch (error) {
  console.error("Failed to load collections", error);
}

const description = "Curated editorial groupings of VentureDex startups.";
const schema = buildJsonLdGraph([
  siteOrganization(Astro.site?.toString()),
  siteWebSite(Astro.site?.toString()),
  webPageNode({
    path: "/collections",
    title: "Collections",
    description,
    type: "CollectionPage",
    siteUrl: Astro.site?.toString(),
  }),
  itemListNode(
    collections.map((collection) => ({
      name: collection.title,
      path: `/collections/${collection.slug}`,
      description: collection.description,
    })),
    Astro.site?.toString()
  ),
]);
---

<Base title="Collections" description={description} canonicalPath="/collections" schema={schema}>
  <div class="container collections-page">
    <header class="page-header">
      <h1>Collections</h1>
      <p>Curated editorial groupings of VentureDex startups.</p>
    </header>

    {collections.length > 0 ? (
      <div class="collections-grid">
        {collections.map((c) => (
          <a href={`/collections/${c.slug}`} class="collection-card">
            <h2>{c.title}</h2>
            {c.description && <p>{c.description}</p>}
            <span class="collection-count">{c.startup_count} startup{c.startup_count !== 1 ? 's' : ''}</span>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <h2>Collections coming soon.</h2>
        <p>We're building curated groupings of the best startups by category.</p>
      </div>
    )}
  </div>
</Base>

<style>
  .collections-page {
    max-width: 1200px;
    padding-block: var(--space-12) var(--space-16);
  }

  .page-header {
    margin-bottom: var(--space-8);
  }

  .page-header h1 {
    font-size: 2rem;
    margin-bottom: var(--space-2);
  }

  .page-header p {
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-width: 640px;
  }

  .collections-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 260px), 1fr));
    gap: var(--space-6);
  }

  .collection-card {
    display: flex;
    flex-direction: column;
    min-width: 0;
    height: 100%;
    padding: var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s;
  }

  .collection-card:hover {
    border-color: var(--color-accent);
    text-decoration: none;
  }

  .collection-card h2 {
    font-size: 1.1rem;
    margin-bottom: var(--space-2);
    overflow-wrap: anywhere;
  }

  .collection-card p {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    line-height: 1.4;
    overflow-wrap: anywhere;
  }

  .collection-count {
    display: block;
    margin-top: auto;
    padding-top: var(--space-3);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-secondary);
  }

  .empty-state {
    text-align: center;
    padding: var(--space-16) 0;
  }

  .empty-state h2 {
    font-size: 1.5rem;
    margin-bottom: var(--space-3);
  }

  .empty-state p {
    color: var(--color-text-secondary);
  }
</style>
