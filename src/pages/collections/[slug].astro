---
export const prerender = false;

import Base from "../../layouts/Base.astro";
import SiteCard from "../../components/SiteCard.astro";
import { getCollectionBySlug } from "../../lib/db";

const { slug } = Astro.params;
const db = Astro.locals.runtime.env.DB;

const data = await getCollectionBySlug(db, slug!);
if (!data) return Astro.redirect("/404");

const { collection, sites } = data;
---

<Base title={collection.title} description={collection.description ?? `${collection.title} on VentureDex`}>
  <div class="container collection-detail">
    <header>
      <a href="/collections" class="back-link">&larr; All collections</a>
      <h1>{collection.title}</h1>
      {collection.description && <p class="description">{collection.description}</p>}
    </header>

    {sites.length > 0 ? (
      <div class="card-grid">
        {sites.map((site) => (
          <SiteCard site={site} />
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <p>No startups in this collection yet.</p>
      </div>
    )}
  </div>
</Base>

<style>
  .collection-detail {
    max-width: 1200px;
    padding: var(--space-12) var(--space-6) var(--space-16);
  }

  .back-link {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    display: inline-block;
    margin-bottom: var(--space-4);
  }

  header h1 {
    font-size: 2rem;
    margin-bottom: var(--space-2);
  }

  .description {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
    max-width: 600px;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  @media (max-width: 900px) {
    .card-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
  }

  .empty-state {
    text-align: center;
    padding: var(--space-12) 0;
    color: var(--color-text-secondary);
  }
</style>
