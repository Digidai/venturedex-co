---
export const prerender = false;

import Base from "../../layouts/Base.astro";
import SiteCard from "../../components/SiteCard.astro";
import { getCollectionBySlug } from "../../lib/db";
import { collectionJsonLd, truncateText } from "../../lib/seo";

const { slug } = Astro.params;
const db = Astro.locals.runtime.env.DB;

const data = await getCollectionBySlug(db, slug!);
if (!data) {
  return new Response("Not found", {
    status: 404,
    headers: { "Content-Type": "text/plain; charset=utf-8" },
  });
}

const { collection, startups } = data;
const description = truncateText(collection.description ?? `${collection.title} on VentureDex`);
const schema = collectionJsonLd(collection, startups, Astro.site?.toString());
---

<Base
  title={collection.title}
  description={description}
  canonicalPath={`/collections/${collection.slug}`}
  schema={schema}
>
  <div class="container collection-detail">
    <header class="collection-header">
      <a href="/collections" class="back-link">&larr; All collections</a>
      <h1>{collection.title}</h1>
      {collection.description && <p class="description">{collection.description}</p>}
    </header>

    {startups.length > 0 ? (
      <div class="card-grid">
        {startups.map((startup) => (
          <SiteCard startup={startup} />
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <p>No startups in this collection yet.</p>
      </div>
    )}
  </div>
</Base>

<style>
  .collection-detail {
    max-width: 1200px;
    padding-block: var(--space-12) var(--space-16);
  }

  .collection-header {
    max-width: 900px;
  }

  .back-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    margin-bottom: var(--space-4);
    transition: color 0.15s;
  }

  header h1 {
    font-size: 2rem;
    margin-bottom: var(--space-2);
  }

  .description {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
    max-width: 600px;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .card-grid > * {
    min-width: 0;
  }

  @media (max-width: 900px) {
    .card-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
  }

  .empty-state {
    text-align: center;
    padding: var(--space-12) 0;
    color: var(--color-text-secondary);
  }
</style>
