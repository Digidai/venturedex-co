---
export const prerender = true;

import Base from "../layouts/Base.astro";
import SiteCard from "../components/SiteCard.astro";
import { getContentStartups } from "../lib/content";
import { buildSearchEntries } from "../lib/search-index";

// Prerendered: all cards ship in the page (browseable with JS off), plus a JSON
// search index. The client scores the index and reorders the matching cards in
// place — no per-request D1, and weighted substring matching (stronger than the
// old prefix-only LIKE on search_index_terms).
const startups = getContentStartups().sort((a, b) =>
  a.product_name.toLowerCase().localeCompare(b.product_name.toLowerCase())
);
const searchEntries = buildSearchEntries(startups);
// Escape "<" so a value containing "</script>" can't break out of the JSON block.
const searchIndexJson = JSON.stringify(searchEntries).split("<").join("\\u003c");
---

<Base
  title="Search"
  description="Search the VentureDex directory of curated startups by name, domain, type, or tag."
  robots="noindex,follow"
>
  <div class="container search-page">
    <h1>Search</h1>

    <form class="search-form" role="search" action="/search" method="GET">
      <input
        type="search"
        name="q"
        placeholder="Search startups by name, domain, type, or tag..."
        class="search-input"
        autocomplete="off"
        aria-label="Search startups"
      />
    </form>

    <p class="result-count" data-result-count hidden></p>

    <div class="search-hints" data-search-hints>
      <p>Try searching for:</p>
      <div class="hint-tags">
        <a href="/search?q=ai" class="hint-tag">AI</a>
        <a href="/search?q=devtools" class="hint-tag">DevTools</a>
        <a href="/search?q=linear" class="hint-tag">Linear</a>
        <a href="/search?q=cursor" class="hint-tag">Cursor</a>
        <a href="/search?q=supabase" class="hint-tag">Supabase</a>
      </div>
    </div>

    <div class="empty-state" data-empty-state hidden>
      <h2 data-empty-title>No results</h2>
      <p>This startup might not be in our directory yet.</p>
    </div>

    <div class="card-grid" data-search-grid hidden>
      {startups.map((startup) => (
        <SiteCard startup={startup} />
      ))}
    </div>

    <noscript>
      {/* With JS off the grid can't be searched, so reveal the full directory. */}
      <style>[data-search-grid]{"{ display: grid !important; }"}</style>
    </noscript>

    <script type="application/json" data-search-index set:html={searchIndexJson} />
  </div>
</Base>

<script>
  // Static client-side search over the prerendered cards. Ranking semantics live
  // in src/lib/search-index.ts (unit-tested); this is the DOM adapter.
  import { rankSearchEntries, type SearchEntry } from "../lib/search-index";

  // Typed DOM lookups — see the note in index.astro: cast through `any` so the
  // global @cloudflare/workers-types DOM-lite doesn't shadow lib.dom here.
  const q = <T,>(sel: string, root: any = document): T | null => (root.querySelector(sel) as T) ?? null;
  const qa = <T,>(sel: string, root: any = document): T[] => Array.from(root.querySelectorAll(sel)) as T[];

  const grid = q<HTMLElement>("[data-search-grid]");
  const form = q<HTMLFormElement>(".search-form");
  const input = q<HTMLInputElement>('input[name="q"]');
  const indexEl = q<HTMLElement>("[data-search-index]");

  if (grid && form && input && indexEl) {
    let entries: SearchEntry[] = [];
    try {
      entries = JSON.parse(indexEl.textContent || "[]");
    } catch {
      entries = [];
    }

    const cardBySlug = new Map<string, HTMLElement>();
    qa<HTMLElement>("[data-slug]", grid).forEach((el) => {
      const slug = el.getAttribute("data-slug");
      if (slug) cardBySlug.set(slug, el);
    });

    const hints = q<HTMLElement>("[data-search-hints]");
    const count = q<HTMLElement>("[data-result-count]");
    const empty = q<HTMLElement>("[data-empty-state]");
    const emptyTitle = q<HTMLElement>("[data-empty-title]");

    function render(raw: string) {
      const q = raw.trim();
      if (!q) {
        grid!.hidden = true;
        if (hints) hints.hidden = false;
        if (count) count.hidden = true;
        if (empty) empty.hidden = true;
        return;
      }
      if (hints) hints.hidden = true;

      const ranked = rankSearchEntries(entries, q);
      const visible = new Set(ranked.map((e) => e.slug));
      cardBySlug.forEach((el, slug) => {
        el.hidden = !visible.has(slug);
      });
      for (const entry of ranked) {
        const el = cardBySlug.get(entry.slug);
        if (el) grid!.appendChild(el);
      }

      grid!.hidden = ranked.length === 0;
      if (count) {
        count.hidden = ranked.length === 0;
        count.textContent = `${ranked.length} result${ranked.length !== 1 ? "s" : ""}`;
      }
      if (empty) {
        empty.hidden = ranked.length !== 0;
        if (emptyTitle && ranked.length === 0) emptyTitle.textContent = `No results for "${q}"`;
      }
    }

    function syncUrl(raw: string) {
      const q = raw.trim();
      history.replaceState(null, "", q ? `/search?q=${encodeURIComponent(q)}` : "/search");
    }

    input.addEventListener("input", () => {
      render(input!.value);
      syncUrl(input!.value);
    });
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      render(input!.value);
      syncUrl(input!.value);
    });

    // Hint links: fill the box and search in place instead of navigating.
    const hintLinks = hints ? qa<HTMLAnchorElement>("a.hint-tag", hints) : [];
    hintLinks.forEach((link) => {
      link.addEventListener("click", (e) => {
        e.preventDefault();
        const query = new URL(link.href).searchParams.get("q") ?? "";
        input!.value = query;
        input!.focus();
        render(query);
        syncUrl(query);
      });
    });

    const initial = new URLSearchParams(location.search).get("q") ?? "";
    if (initial) input.value = initial;
    render(input.value);
  }
</script>

<style>
  .search-page {
    max-width: 1200px;
    padding: var(--space-12) var(--space-6) var(--space-16);
  }

  .search-page h1 {
    font-size: 2rem;
    margin-bottom: var(--space-6);
  }

  .search-form {
    margin-bottom: var(--space-8);
  }

  .search-input {
    width: 100%;
    max-width: 600px;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-family: var(--font-body);
    font-size: 1rem;
    background: var(--color-bg-card);
    color: var(--color-text);
    -webkit-appearance: none;
    appearance: none;
  }

  .search-input:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: -1px;
    border-color: transparent;
  }

  .search-input::-webkit-search-cancel-button {
    -webkit-appearance: none;
  }

  .result-count {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-6);
  }

  .empty-state {
    text-align: center;
    padding: var(--space-12) 0;
  }

  .empty-state h2 {
    font-size: 1.25rem;
    margin-bottom: var(--space-2);
  }

  .empty-state p {
    color: var(--color-text-secondary);
  }

  .search-hints {
    padding: var(--space-4) 0;
  }

  .search-hints p {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-3);
  }

  .hint-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .hint-tag {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: 99px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }

  .hint-tag:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    text-decoration: none;
  }
</style>
