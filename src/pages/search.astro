---
export const prerender = false;

import Base from "../layouts/Base.astro";
import SiteCard from "../components/SiteCard.astro";
import { searchStartups } from "../lib/db";

const query = (Astro.url.searchParams.get("q") ?? "").trim();
const db = Astro.locals.runtime.env.DB;

let results: Awaited<ReturnType<typeof searchStartups>> = [];
if (query.trim()) {
  try {
    results = await searchStartups(db, query);
  } catch (error) {
    console.error("Failed to search startups", error);
  }
}
---

<Base
  title={query ? `Search: ${query}` : "Search"}
  description="Search the VentureDex directory."
  robots="noindex,follow"
>
  <div class="container search-page">
    <h1>Search</h1>

    <form class="search-form" action="/search" method="GET">
      <label for="search-query" class="visually-hidden">Search startups</label>
      <input
        id="search-query"
        type="search"
        name="q"
        value={query}
        placeholder="Search startups by name, domain, or tag..."
        class="search-input"
      />
    </form>

    {query && results.length > 0 && (
      <p class="result-count">{results.length} result{results.length !== 1 ? "s" : ""}</p>
    )}

    {results.length > 0 ? (
      <div class="card-grid">
        {results.map((startup) => (
          <SiteCard startup={startup} />
        ))}
      </div>
    ) : query ? (
      <div class="empty-state">
        <h2>No results for "{query}"</h2>
        <p>This startup might not be in our directory yet.</p>
      </div>
    ) : (
      <div class="search-hints">
        <p>Try searching for:</p>
        <div class="hint-tags">
          <a href="/search?q=ai" class="hint-tag">AI</a>
          <a href="/search?q=devtools" class="hint-tag">DevTools</a>
          <a href="/search?q=linear" class="hint-tag">Linear</a>
          <a href="/search?q=cursor" class="hint-tag">Cursor</a>
          <a href="/search?q=supabase" class="hint-tag">Supabase</a>
        </div>
      </div>
    )}
  </div>
</Base>

<style>
  .search-page {
    max-width: 1200px;
    padding: var(--space-12) var(--space-6) var(--space-16);
  }

  .search-page h1 {
    font-size: 2rem;
    margin-bottom: var(--space-6);
  }

  .search-form {
    margin-bottom: var(--space-8);
  }

  .search-input {
    width: 100%;
    max-width: 600px;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-family: var(--font-body);
    font-size: 1rem;
    background: var(--color-bg-card);
    color: var(--color-text);
    -webkit-appearance: none;
    appearance: none;
  }

  .search-input:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: -1px;
    border-color: transparent;
  }

  .search-input::-webkit-search-cancel-button {
    -webkit-appearance: none;
  }

  .result-count {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-6);
  }

  .empty-state {
    text-align: center;
    padding: var(--space-12) 0;
  }

  .empty-state h2 {
    font-size: 1.25rem;
    margin-bottom: var(--space-2);
  }

  .empty-state p {
    color: var(--color-text-secondary);
  }

  .search-hints {
    padding: var(--space-4) 0;
  }

  .search-hints p {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-3);
  }

  .hint-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .hint-tag {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: 99px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }

  .hint-tag:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    text-decoration: none;
  }
</style>
