---
export const prerender = false;

import Base from "../layouts/Base.astro";
import {
  buildJsonLdGraph,
  siteOrganization,
  siteWebSite,
  webPageNode,
} from "../lib/seo";

const title = "Sponsor VentureDex Startup Research";
const description = "Reach founders, investors, and builders through VentureDex. Get in touch at hi@venturedex.co to discuss sponsorship.";
const schema = buildJsonLdGraph([
  siteOrganization(Astro.site?.toString()),
  siteWebSite(Astro.site?.toString()),
  webPageNode({
    path: "/sponsor",
    title,
    description,
    siteUrl: Astro.site?.toString(),
  }),
]);
---

<Base title={title} description={description} schema={schema}>
  <div class="container sponsor-page">
    <h1>Sponsor VentureDex</h1>
    <p class="subtitle">
      Want to reach founders, investors, and builders who read every pick?
      We'd love to hear from you.
    </p>

    <div class="contact-card">
      <p class="contact-label">Get in touch</p>
      <a class="contact-email" href="mailto:hi@venturedex.co">hi@venturedex.co</a>
      <p class="contact-note">
        Tell us about your product and what you have in mind — we'll reply with placement options.
      </p>
    </div>
  </div>
</Base>

<style>
  .sponsor-page {
    max-width: 560px;
    padding: var(--space-16) var(--space-6);
    text-align: center;
  }

  .sponsor-page > h1 {
    font-size: 2rem;
    margin-bottom: var(--space-3);
  }

  .subtitle {
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-8);
  }

  .contact-card {
    padding: var(--space-8) var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg-card);
  }

  .contact-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-3);
  }

  .contact-email {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 2px solid var(--color-accent);
    padding-bottom: 2px;
  }

  .contact-email:hover {
    opacity: 0.8;
  }

  .contact-note {
    margin-top: var(--space-4);
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--color-text-secondary);
  }
</style>
