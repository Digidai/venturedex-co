---
export const prerender = false;

import BrandLogo from "../components/BrandLogo.astro";
import Base from "../layouts/Base.astro";
import {
  getCompanyBrandAsset,
  getInvestorBrandAsset,
  resolveInvestorByName,
} from "../lib/brand-assets";
import {
  NEWS_ROUNDS_LIMIT,
  getNewsFundingRounds,
} from "../lib/db";
import { newsJsonLd, normalizeExternalUrl } from "../lib/seo";

const db = Astro.locals.runtime.env.DB;
let rounds: Awaited<ReturnType<typeof getNewsFundingRounds>> = [];

try {
  rounds = await getNewsFundingRounds(db, NEWS_ROUNDS_LIMIT);
} catch (error) {
  console.error("Failed to load funding news", error);
}

const description = "Recent funding rounds with verified press sources and official company and investor logos.";
const schema = newsJsonLd(rounds, Astro.site?.toString());
---

<Base title="News" description={description} schema={schema}>
  <div class="container news-page">
    <header class="news-header">
      <h1>Latest funding news</h1>
      <p class="subtitle">Homepage ticker and this table use the same verified rounds: published startups only, with press links only.</p>
    </header>

    {rounds.length > 0 ? (
      <div class="table-wrap">
        <table class="funding-table">
          <colgroup>
            <col class="col-company" />
            <col class="col-round" />
            <col class="col-date" />
            <col class="col-investor" />
            <col class="col-source" />
          </colgroup>
          <thead>
            <tr>
              <th>Company</th>
              <th>Round</th>
              <th>Date</th>
              <th>Lead Investor</th>
              <th>Press</th>
            </tr>
          </thead>
          <tbody>
            {rounds.map((r) => {
              const companyBrand = getCompanyBrandAsset(r.company_slug);
              const investor = resolveInvestorByName(r.lead_investor);
              const investorBrand = investor ? getInvestorBrandAsset(investor.slug) : null;
              const sourceUrl = normalizeExternalUrl(r.source_url);

              return (
                <tr>
                  <td class="cell-company" data-label="Company">
                    <div class="company-info">
                      <BrandLogo asset={companyBrand} name={r.company_name} size={24} />
                      {r.company_slug ? (
                        <a href={`/startups/${r.company_slug}`} class="company-link">
                          {r.company_name}
                        </a>
                      ) : (
                        <span>{r.company_name}</span>
                      )}
                    </div>
                  </td>
                  <td class="cell-round" data-label="Round">
                    {r.amount ? (
                      <>
                        <span class="round-amount">{r.amount}</span>
                        <span class="round-stage">· {r.stage}</span>
                      </>
                    ) : (
                      <span class="round-stage">{r.stage}</span>
                    )}
                  </td>
                  <td class="cell-date" data-label="Date">
                    {new Date(`${r.date}T00:00:00`).toLocaleDateString("en-US", {
                      month: "short",
                      day: "numeric",
                      year: "numeric",
                    })}
                  </td>
                  <td class="cell-investor" data-label="Lead">
                    <div class="investor-info">
                      <BrandLogo asset={investorBrand} name={r.lead_investor || "Investor"} size={24} />
                      {investor ? (
                        <a href={`/investors/${investor.slug}`} class="investor-link">
                          {r.lead_investor}
                        </a>
                      ) : (
                        <span>{r.lead_investor || "—"}</span>
                      )}
                    </div>
                  </td>
                  <td class="cell-source" data-label="Press">
                    {sourceUrl ? (
                      <a href={sourceUrl} target="_blank" rel="noopener noreferrer" class="source-link">
                        {r.source_name || "Press"} ↗
                      </a>
                    ) : (
                      <span class="source-link source-link--missing">{r.source_name || "Press"}</span>
                    )}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    ) : (
      <div class="empty-state">
        <h2>No funding data yet.</h2>
        <p>We only show published startups with a verified press link. Check back soon.</p>
      </div>
    )}
  </div>
</Base>

<style>
  .news-page {
    max-width: 1000px;
    padding: var(--space-12) var(--space-6) var(--space-16);
  }

  .news-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .news-header h1 {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    margin-bottom: var(--space-2);
  }

  .subtitle {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .table-wrap {
    overflow-x: auto;
  }

  .funding-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }

  .col-company {
    width: 24%;
  }

  .col-round {
    width: 15%;
  }

  .col-date {
    width: 16%;
  }

  .col-investor {
    width: 28%;
  }

  .col-source {
    width: 17%;
  }

  .funding-table thead th {
    text-align: left;
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-secondary);
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .funding-table tbody tr {
    border-bottom: 1px solid var(--color-border);
    transition: background 0.1s;
  }

  .funding-table tbody tr:hover {
    background: var(--color-badge-bg);
  }

  .funding-table td {
    padding: var(--space-4);
    font-size: 0.85rem;
    vertical-align: middle;
  }

  .cell-company,
  .cell-investor {
    font-weight: 600;
    white-space: nowrap;
  }

  .company-info,
  .investor-info {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    min-width: 0;
  }

  .company-link,
  .investor-link {
    color: var(--color-text);
    text-decoration: none;
    overflow-wrap: anywhere;
  }

  .company-link:hover,
  .investor-link:hover {
    color: var(--color-accent);
  }

  .round-amount {
    color: var(--color-accent);
    font-weight: 600;
  }

  .round-stage,
  .cell-date {
    color: var(--color-text-secondary);
  }

  .cell-round {
    white-space: nowrap;
  }

  .cell-date {
    white-space: nowrap;
  }

  .source-link {
    color: var(--color-text-secondary);
    font-size: 0.8rem;
    text-decoration: none;
    overflow-wrap: anywhere;
  }

  .source-link:hover {
    color: var(--color-accent);
  }

  .source-link--missing:hover {
    color: var(--color-text-secondary);
  }

  .empty-state {
    text-align: center;
    padding: var(--space-16) 0;
  }

  .empty-state h2 {
    font-size: 1.5rem;
    margin-bottom: var(--space-3);
  }

  .empty-state p {
    color: var(--color-text-secondary);
  }

  @media (max-width: 760px) {
    .news-page {
      padding: var(--space-8) var(--space-4) var(--space-12);
    }

    .news-header {
      text-align: left;
      margin-bottom: var(--space-8);
    }

    .table-wrap {
      overflow-x: visible;
    }

    .funding-table,
    .funding-table colgroup,
    .funding-table thead,
    .funding-table tbody,
    .funding-table tr,
    .funding-table td {
      display: block;
      width: 100%;
    }

    .funding-table thead {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0 0 0 0);
      white-space: nowrap;
    }

    .funding-table tbody {
      display: grid;
      gap: var(--space-3);
    }

    .funding-table tbody tr {
      display: grid;
      gap: var(--space-3);
      padding: var(--space-4);
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      background: var(--color-bg-card);
    }

    .funding-table tbody tr:hover {
      background: var(--color-bg-card);
    }

    .funding-table td {
      display: grid;
      grid-template-columns: minmax(5.5rem, 32%) minmax(0, 1fr);
      gap: var(--space-3);
      align-items: center;
      padding: 0;
      min-width: 0;
    }

    .funding-table td::before {
      content: attr(data-label);
      color: var(--color-text-secondary);
      font-size: 0.68rem;
      font-weight: 500;
      letter-spacing: 0.06em;
      line-height: 1.2;
      text-transform: uppercase;
    }

    .cell-company,
    .cell-investor,
    .cell-round,
    .cell-date {
      white-space: normal;
    }

    .company-info,
    .investor-info {
      gap: var(--space-2);
    }

    .company-link,
    .investor-link,
    .source-link {
      display: inline-flex;
      align-items: center;
      min-height: 44px;
    }
  }
</style>
