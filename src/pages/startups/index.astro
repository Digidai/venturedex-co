---
export const prerender = false;

import Base from "../../layouts/Base.astro";
import SiteCard from "../../components/SiteCard.astro";
import { getPublishedStartups } from "../../lib/db";
import {
  buildJsonLdGraph,
  itemListNode,
  siteOrganization,
  siteWebSite,
  webPageNode,
} from "../../lib/seo";

const db = Astro.locals.runtime.env.DB;
let startups: Awaited<ReturnType<typeof getPublishedStartups>> = [];

try {
  startups = await getPublishedStartups(db, { limit: 500, sort: "newest" });
} catch (error) {
  console.error("Failed to load startups index", error);
}

const description = "Browse all published VentureDex startup profiles with editorial context, funding stage, and investor signals.";
const schema = buildJsonLdGraph([
  siteOrganization(Astro.site?.toString()),
  siteWebSite(Astro.site?.toString()),
  webPageNode({
    path: "/startups",
    title: "Startups",
    description,
    type: "CollectionPage",
    siteUrl: Astro.site?.toString(),
  }),
  itemListNode(
    startups.map((startup) => ({
      name: startup.product_name,
      path: `/startups/${startup.slug}`,
      description: startup.summary,
    })),
    Astro.site?.toString()
  ),
]);
---

<Base title="Startups" description={description} schema={schema}>
  <div class="container startups-page">
    <header class="page-header">
      <h1>Startups</h1>
      <p>{description}</p>
    </header>

    {startups.length > 0 ? (
      <div class="card-grid">
        {startups.map((startup) => (
          <SiteCard startup={startup} />
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <h2>No startups yet.</h2>
        <p>Published startup profiles will appear here.</p>
      </div>
    )}
  </div>
</Base>

<style>
  .startups-page {
    max-width: 1200px;
    padding: var(--space-12) var(--space-6) var(--space-16);
  }

  .page-header {
    margin-bottom: var(--space-8);
  }

  .page-header h1 {
    font-size: 2rem;
    margin-bottom: var(--space-2);
  }

  .page-header p {
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-width: 640px;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .empty-state {
    text-align: center;
    padding: var(--space-12) 0;
  }

  .empty-state h2 {
    font-size: 1.5rem;
    margin-bottom: var(--space-3);
  }

  .empty-state p {
    color: var(--color-text-secondary);
  }

  @media (max-width: 900px) {
    .card-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
