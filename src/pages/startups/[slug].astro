---
export const prerender = true;

import Base from "../../layouts/Base.astro";
import BrandLogo from "../../components/BrandLogo.astro";
import SiteCard from "../../components/SiteCard.astro";
import {
  getCompanyBrandAsset,
  getInvestorBrandAsset,
  resolveInvestorByName,
} from "../../lib/brand-assets";
import {
  getContentFundingRoundsForStartup,
  getContentRelatedStartups,
  getContentStartupBySlug,
  getContentStartups,
} from "../../lib/content";
import { normalizeLinks, normalizeResearch, safeJsonParse } from "../../lib/json";
import { normalizeExternalUrl, startupJsonLd, truncateText } from "../../lib/seo";
import type { StartupLinks, StartupResearch, StartupResearchSource } from "../../lib/types";

export function getStaticPaths() {
  return getContentStartups().map((startup) => ({ params: { slug: startup.slug } }));
}

const { slug } = Astro.params;
const startup = getContentStartupBySlug(slug!)!;

const related = getContentRelatedStartups(startup);
const fundingRounds = getContentFundingRoundsForStartup(startup.slug);
const screenshotUrl = startup.screenshot_r2_key ? `/screenshots/${startup.screenshot_r2_key}` : null;
const companyBrand = getCompanyBrandAsset(startup.slug);

const investors = startup.investors
  ? startup.investors.split(",").map((s) => s.trim()).filter(Boolean)
  : [];
const fundingContext = [
  startup.product_type,
  startup.funding_display ?? startup.funding_stage,
  investors.length > 0 ? `Investors: ${investors.slice(0, 3).join(", ")}` : null,
  startup.region,
].filter(Boolean).join(" · ");
const description = truncateText([
  startup.summary ?? startup.editor_note ?? `${startup.product_name} startup profile on VentureDex`,
  fundingContext,
].filter(Boolean).join(" "));
// Keep the full <title> (Base appends " | VentureDex", 13 chars) under ~60 for Google.
const TITLE_MAX = 46;
const enrichedPageTitle = `${startup.product_name} ${startup.product_type} Startup Profile`;
const basicPageTitle = `${startup.product_name} Startup Profile`;
const pageTitle = enrichedPageTitle.length <= TITLE_MAX
  ? enrichedPageTitle
  : basicPageTitle.length <= TITLE_MAX
    ? basicPageTitle
    : startup.product_name;
const schema = startupJsonLd(startup, Astro.site?.toString());

const tags = startup.tags
  ? startup.tags.split(",").map((s) => s.trim()).filter(Boolean)
  : [];

const investorEntries = investors.map((name) => {
  const investor = resolveInvestorByName(name);
  return {
    name,
    slug: investor?.slug ?? null,
    logo: investor ? getInvestorBrandAsset(investor.slug) : null,
  };
});

const links: StartupLinks = safeJsonParse(startup.links_json, normalizeLinks) ?? {};
const research: StartupResearch | null = safeJsonParse(startup.research_json, normalizeResearch);

const hasTeamInfo = !!(startup.founder_name || startup.team_size || startup.hq_location);
const websiteUrl = normalizeExternalUrl(startup.canonical_url) ?? normalizeExternalUrl(startup.domain);

const externalLinks = [
  websiteUrl ? { label: "Website", url: websiteUrl } : null,
  links.github ? { label: "GitHub", url: normalizeExternalUrl(links.github) } : null,
  links.twitter ? { label: "X / Twitter", url: normalizeExternalUrl(links.twitter) } : null,
  links.linkedin ? { label: "LinkedIn", url: normalizeExternalUrl(links.linkedin) } : null,
  links.producthunt ? { label: "Product Hunt", url: normalizeExternalUrl(links.producthunt) } : null,
].filter((link): link is { label: string; url: string } => Boolean(link?.url));

const researchSources = research?.sources ?? [];
const sourceById = new Map(researchSources.map((source) => [source.id, source]));
const latestFunding = fundingRounds[0] ?? null;

const sourceTrail = [
  websiteUrl ? { id: "official_site", label: "Official site", url: websiteUrl, type: "official" } : null,
  ...fundingRounds.map((round, index) => (
    round.source_url
      ? {
          id: `funding_${index + 1}`,
          label: round.source_name ? `${round.source_name} funding source` : "Funding source",
          url: normalizeExternalUrl(round.source_url),
          type: "funding",
        }
      : null
  )),
  ...researchSources.map((source) => ({
    id: source.id,
    label: source.label,
    url: normalizeExternalUrl(source.url),
    type: source.type,
  })),
].filter((source): source is { id: string; label: string; url: string; type: string } => Boolean(source?.url));

const uniqueSourceTrail = Array.from(
  new Map(sourceTrail.map((source) => [source.url, source])).values()
);

function formatDate(date: string | null | undefined) {
  if (!date) return "";
  return new Date(date).toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  });
}

function sourceLabel(source?: StartupResearchSource) {
  return source?.label ?? "Source";
}
---

<Base
  title={pageTitle}
  description={description}
  ogImage={screenshotUrl ?? undefined}
  ogType="article"
  ogImageWidth={screenshotUrl ? 1440 : undefined}
  ogImageHeight={screenshotUrl ? 900 : undefined}
  ogImageType={screenshotUrl ? "image/webp" : undefined}
  publishedTime={startup.published_at}
  modifiedTime={startup.updated_at}
  schema={schema}
>
  <article class="site-detail container">
    <div class="detail-hero">
      {screenshotUrl ? (
        <img src={screenshotUrl} alt={`${startup.product_name} screenshot`} class="detail-screenshot" />
      ) : (
        <div class="detail-placeholder">
          <span>{startup.product_name.charAt(0)}</span>
        </div>
      )}
    </div>

    <header class="detail-header">
      <div class="header-top">
        <div class="detail-title-wrap">
          <BrandLogo asset={companyBrand} name={startup.product_name} size={36} class="detail-logo" />
          <div>
          <h1>{startup.product_name}</h1>
          <p class="detail-domain">{startup.domain}</p>
          </div>
        </div>
        <a
          href={websiteUrl ?? `https://${startup.domain}`}
          target="_blank"
          rel="noopener noreferrer"
          class="visit-button"
        >
          Visit Site &rarr;
        </a>
      </div>
      {startup.summary && <p class="detail-summary">{startup.summary}</p>}
    </header>

    <dl class="score-strip" aria-label="VentureDex summary">
      {startup.editor_rating && (
        <div class="score-item">
          <dt>VentureDex rating</dt>
          <dd>{startup.editor_rating}/5</dd>
        </div>
      )}
      {latestFunding && (
        <div class="score-item">
          <dt>Latest funding</dt>
          <dd>
            {latestFunding.amount ? `${latestFunding.amount} ` : ""}{latestFunding.stage}
            {latestFunding.lead_investor ? ` · ${latestFunding.lead_investor}` : ""}
          </dd>
        </div>
      )}
      {research?.verified_at && (
        <div class="score-item">
          <dt>Research checked</dt>
          <dd>{formatDate(research.verified_at)}</dd>
        </div>
      )}
    </dl>

    {startup.editor_note && (
      <section class="editor-note" aria-label="Editor's note">
        <p class="note-text">{startup.editor_note}</p>
        <p class="note-meta">
          Curated by {startup.curator}
          {startup.published_at && ` on ${new Date(startup.published_at).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}`}
        </p>
      </section>
    )}

    {startup.founder_quote && (
      <section class="founder-quote" aria-label="Founder's words">
        <blockquote>
          <p>"{startup.founder_quote}"</p>
          {startup.founder_name && <cite>— {startup.founder_name}</cite>}
        </blockquote>
      </section>
    )}

    {latestFunding && (
      <section class="funding-section" aria-label="Funding event">
        <div class="section-heading">
          <h2>Funding signal</h2>
          {latestFunding.source_url && (
            <a href={latestFunding.source_url} target="_blank" rel="noopener noreferrer">
              {latestFunding.source_name ?? "Source"} &nearr;
            </a>
          )}
        </div>
        <p>
          {startup.product_name} raised {latestFunding.amount ?? "an undisclosed amount"} at {latestFunding.stage}
          {latestFunding.lead_investor ? ` led by ${latestFunding.lead_investor}` : ""}
          {latestFunding.date ? ` on ${formatDate(latestFunding.date)}` : ""}.
        </p>
      </section>
    )}

    {research?.product_evidence?.length ? (
      <section class="evidence-section" aria-label="Product evidence">
        <h2>Product evidence</h2>
        <div class="evidence-list">
          {research.product_evidence.map((item) => (
            <article class="evidence-item">
              <p>{item.claim}</p>
              <div class="evidence-sources">
                {item.source_ids.map((sourceId) => {
                  const source = sourceById.get(sourceId);
                  return source?.url ? (
                    <a href={source.url} target="_blank" rel="noopener noreferrer">
                      {sourceLabel(source)} &nearr;
                    </a>
                  ) : (
                    <span>{sourceLabel(source)}</span>
                  );
                })}
              </div>
            </article>
          ))}
        </div>
      </section>
    ) : null}

    {research?.market_context && (
      <section class="market-section" aria-label="Market context">
        <h2>Market context</h2>
        <dl class="context-grid">
          {research.market_context.primary_user && (
            <div>
              <dt>Primary user</dt>
              <dd>{research.market_context.primary_user}</dd>
            </div>
          )}
          {research.market_context.category && (
            <div>
              <dt>Category</dt>
              <dd>{research.market_context.category}</dd>
            </div>
          )}
          {research.market_context.differentiation && (
            <div>
              <dt>Differentiation</dt>
              <dd>{research.market_context.differentiation}</dd>
            </div>
          )}
          {research.market_context.why_now && (
            <div>
              <dt>Why now</dt>
              <dd>{research.market_context.why_now}</dd>
            </div>
          )}
        </dl>
      </section>
    )}

    {research?.risks?.length ? (
      <section class="risk-section" aria-label="Risks and open questions">
        <h2>Risks and open questions</h2>
        <div class="risk-list">
          {research.risks.map((risk) => (
            <article class="risk-item">
              <p>{risk.claim}</p>
              <span>{risk.basis}</span>
            </article>
          ))}
        </div>
      </section>
    ) : null}

    <section class="detail-meta">
      <div class="meta-grid">
        {startup.product_type && (
          <div class="meta-item">
            <dt>Type</dt>
            <dd>{startup.product_type}</dd>
          </div>
        )}
        {startup.funding_stage && (
          <div class="meta-item">
            <dt>Stage</dt>
            <dd>{startup.funding_stage}{startup.funding_display ? ` (${startup.funding_display})` : ""}</dd>
          </div>
        )}
        {startup.region && (
          <div class="meta-item">
            <dt>Region</dt>
            <dd>{startup.region}</dd>
          </div>
        )}
        {startup.founded_year && (
          <div class="meta-item">
            <dt>Founded</dt>
            <dd>{startup.founded_year}</dd>
          </div>
        )}
        {startup.framework && (
          <div class="meta-item">
            <dt>Built with</dt>
            <dd>{startup.framework}</dd>
          </div>
        )}
        {startup.why_featured && (
          <div class="meta-item">
            <dt>Why featured</dt>
            <dd class="why-badge">
              <span class="why-badge-dot" aria-hidden="true"></span>
              <span>{startup.why_featured}</span>
            </dd>
          </div>
        )}
      </div>
    </section>

    {hasTeamInfo && (
      <section class="team-section" aria-label="Team">
        <h2>Team</h2>
        <div class="team-grid">
          {startup.founder_name && (
            <div class="team-item">
              <dt>Founder</dt>
              <dd>{startup.founder_name}</dd>
            </div>
          )}
          {startup.team_size && (
            <div class="team-item">
              <dt>Team Size</dt>
              <dd>{startup.team_size}</dd>
            </div>
          )}
          {startup.hq_location && (
            <div class="team-item">
              <dt>Headquarters</dt>
              <dd>{startup.hq_location}</dd>
            </div>
          )}
        </div>
      </section>
    )}

    {investors.length > 0 && (
      <section class="investors-section" aria-label="Investors">
        <h2>Investors</h2>
        <div class="pill-list">
          {investorEntries.map((investor) => (
            investor.slug ? (
              <a href={`/investors/${investor.slug}`} class="pill pill-link">
                <BrandLogo asset={investor.logo} name={investor.name} size={18} />
                <span>{investor.name}</span>
              </a>
            ) : (
              <span class="pill">
                <BrandLogo asset={investor.logo} name={investor.name} size={18} />
                <span>{investor.name}</span>
              </span>
            )
          ))}
        </div>
      </section>
    )}

    {externalLinks.length > 1 && (
      <section class="links-section" aria-label="External links">
        <h2>Links</h2>
        <div class="links-row">
          {externalLinks.map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="ext-link"
            >
              {link.label} &nearr;
            </a>
          ))}
        </div>
      </section>
    )}

    {uniqueSourceTrail.length > 0 && (
      <section class="sources-section" aria-label="Sources">
        <h2>Source trail</h2>
        <div class="source-list">
          {uniqueSourceTrail.map((source) => (
            <a href={source.url} target="_blank" rel="noopener noreferrer" class="source-link">
              <span>{source.label}</span>
              <small>{source.type}</small>
            </a>
          ))}
        </div>
      </section>
    )}

    {tags.length > 0 && (
      <section class="tags-section" aria-label="Tags">
        <h2>Tags</h2>
        <div class="tag-list">
          {tags.map((tag) => (
            <a href={`/search?q=${encodeURIComponent(tag)}`} class="tag-badge">{tag}</a>
          ))}
        </div>
      </section>
    )}

    {related.length > 0 && (
      <section class="related">
        <h2>Related startups</h2>
        <div class="related-grid">
          {related.map((r) => (
            <SiteCard startup={r} />
          ))}
        </div>
      </section>
    )}
  </article>
</Base>

<style>
  .site-detail {
    padding: var(--space-8) var(--space-6) var(--space-16);
    width: min(900px, 100vw);
    max-width: 100%;
  }

  .detail-hero {
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--color-border);
    margin-bottom: var(--space-8);
  }

  .detail-screenshot {
    width: 100%;
    max-height: 500px;
    object-fit: cover;
    object-position: top;
    display: block;
  }

  .detail-placeholder {
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-badge-bg);
    font-family: var(--font-heading);
    font-size: 4rem;
    color: var(--color-text-secondary);
  }

  .detail-header {
    margin-bottom: var(--space-8);
  }

  .score-strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-4);
    padding: var(--space-4) 0 var(--space-8);
    margin-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .score-item dt,
  .context-grid dt {
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-1);
  }

  .score-item dd {
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.35;
  }

  .header-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-4);
    margin-bottom: var(--space-3);
  }

  .detail-title-wrap {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    min-width: 0;
  }

  .detail-title-wrap > div {
    min-width: 0;
  }

  .detail-header h1 {
    font-size: 2rem;
    margin-bottom: var(--space-1);
  }

  .detail-domain {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    overflow-wrap: anywhere;
  }

  .visit-button {
    display: inline-flex;
    align-items: center;
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    white-space: nowrap;
    transition: border-color 0.15s;
  }

  .visit-button:hover {
    border-color: var(--color-accent);
    text-decoration: none;
  }

  .detail-summary {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .detail-summary,
  .note-text,
  .funding-section p,
  .evidence-item p,
  .risk-item p,
  .context-grid dd,
  .source-link span {
    overflow-wrap: break-word;
  }

  .editor-note {
    border-left: 3px solid var(--color-editor-line);
    padding: var(--space-4) var(--space-6);
    margin-bottom: var(--space-6);
    background: color-mix(in srgb, var(--color-accent) 5%, var(--color-bg-card));
    border-radius: 0 var(--radius) var(--radius) 0;
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-editor-line);
  }

  .funding-section,
  .evidence-section,
  .market-section,
  .risk-section,
  .sources-section {
    padding-bottom: var(--space-8);
    margin-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .section-heading {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    align-items: baseline;
    margin-bottom: var(--space-3);
  }

  .funding-section h2,
  .evidence-section h2,
  .market-section h2,
  .risk-section h2,
  .sources-section h2 {
    font-size: 1.1rem;
    margin-bottom: var(--space-4);
  }

  .section-heading h2 {
    margin-bottom: 0;
  }

  .section-heading a {
    font-size: 0.8rem;
    white-space: nowrap;
  }

  .funding-section p {
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .evidence-list,
  .risk-list {
    display: grid;
    gap: var(--space-3);
  }

  .evidence-item,
  .risk-item {
    padding: var(--space-4) 0;
    border-top: 1px solid var(--color-border);
  }

  .evidence-item p,
  .risk-item p {
    margin: 0 0 var(--space-2);
    line-height: 1.55;
  }

  .evidence-sources {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    font-size: 0.75rem;
    color: var(--color-text-secondary);
  }

  .evidence-sources a,
  .evidence-sources span,
  .risk-item span {
    color: var(--color-text-secondary);
    font-size: 0.75rem;
  }

  .context-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-5);
  }

  .context-grid dd {
    color: var(--color-text-secondary);
    line-height: 1.5;
    font-size: 0.9rem;
  }

  .source-list {
    display: grid;
    gap: var(--space-2);
  }

  .source-link {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-3) 0;
    border-top: 1px solid var(--color-border);
    color: var(--color-text);
    text-decoration: none;
  }

  .source-link:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .source-link small {
    color: var(--color-text-secondary);
    text-transform: capitalize;
  }

  .note-text {
    font-size: 1.05rem;
    font-style: italic;
    line-height: 1.6;
    margin-bottom: var(--space-2);
  }

  .note-meta {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  .founder-quote {
    margin-bottom: var(--space-8);
  }

  .founder-quote blockquote {
    border-left: 2px solid var(--color-border);
    padding-left: var(--space-4);
  }

  .founder-quote p {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  .founder-quote cite {
    font-size: 0.85rem;
    font-style: normal;
    color: var(--color-text-secondary);
    display: block;
    margin-top: var(--space-2);
  }

  .detail-meta {
    padding-bottom: var(--space-8);
    margin-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .meta-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: var(--space-4);
  }

  .meta-item dt {
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-1);
  }

  .meta-item dd {
    font-size: 0.9rem;
  }

  .why-badge {
    display: inline-grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: center;
    gap: 8px;
    max-width: min(100%, 30rem);
    padding: 7px 12px;
    border-radius: 6px;
    border: 1px solid color-mix(in srgb, var(--color-accent) 18%, var(--color-border));
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--color-accent) 12%, transparent) 0%, color-mix(in srgb, var(--color-bg-card) 92%, transparent) 100%);
    color: var(--color-accent);
    font-size: 0.82rem;
    font-weight: 600;
    line-height: 1.35;
    box-shadow: 0 1px 0 color-mix(in srgb, var(--color-accent) 12%, transparent);
  }

  .why-badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--color-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 16%, transparent);
  }

  /* Team section */
  .team-section {
    margin-bottom: var(--space-8);
  }

  .team-section h2 {
    font-size: 1.1rem;
    margin-bottom: var(--space-4);
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: var(--space-4);
  }

  .team-item dt {
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-1);
  }

  .team-item dd {
    font-size: 0.9rem;
  }

