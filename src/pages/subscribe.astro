---
export const prerender = false;

import Base from "../layouts/Base.astro";

const status = Astro.url.searchParams.get("status");
const error = Astro.url.searchParams.get("error");
const errorMessage = error === "invalid"
  ? "Enter a valid email address."
  : error === "failed"
    ? "We couldn't subscribe you right now. Try again in a moment."
    : null;
---

<Base title="Subscribe" description="Get the best startups delivered to your inbox every week.">
  <div class="container subscribe-page">
    <h1>Stay in the loop.</h1>
    <p class="subtitle">
      Every week, we pick 5-7 startups worth your attention. With editorial commentary.
      No spam, no fluff, just the good stuff.
    </p>

    {(status === "subscribed" || errorMessage) && (
      <p id="subscribe-message" class:list={["form-message", errorMessage ? "form-message--error" : "form-message--success"]} role={errorMessage ? "alert" : "status"}>
        {errorMessage ?? "You're subscribed. Watch your inbox for the next issue."}
      </p>
    )}

    <form class="subscribe-form" action="/api/subscribe" method="POST">
      <label for="subscribe-email" class="visually-hidden">Email address</label>
      <input
        id="subscribe-email"
        type="email"
        name="email"
        required
        placeholder="you@example.com"
        class="email-input"
        autocomplete="email"
        aria-invalid={errorMessage ? "true" : "false"}
        aria-describedby={errorMessage ? "subscribe-message" : undefined}
      />
      <button type="submit" class="submit-button">Subscribe</button>
    </form>

    <p class="note">Unsubscribe anytime. We respect your inbox.</p>
  </div>
</Base>

<style>
  .subscribe-page {
    max-width: 500px;
    padding-block: var(--space-16);
    text-align: center;
  }

  .subscribe-page h1 {
    font-size: 2rem;
    margin-bottom: var(--space-3);
  }

  .subtitle {
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-8);
  }

  .subscribe-form {
    display: flex;
    gap: var(--space-2);
    width: 100%;
    max-width: 400px;
    margin: 0 auto var(--space-4);
  }

  .email-input {
    flex: 1;
    min-width: 0;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-family: var(--font-body);
    font-size: 0.9rem;
    background: var(--color-bg-card);
    color: var(--color-text);
  }

  .email-input:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: -1px;
    border-color: transparent;
  }

  .submit-button {
    padding: var(--space-3) var(--space-6);
    background: var(--color-text);
    color: var(--color-bg);
    border: none;
    border-radius: var(--radius);
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.9rem;
    white-space: nowrap;
    cursor: pointer;
    transition: opacity 0.15s;
  }

  .submit-button:hover {
    opacity: 0.85;
  }

  .note {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  .form-message {
    max-width: 400px;
    margin: 0 auto var(--space-4);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius);
    color: var(--color-text);
    font-size: 0.9rem;
    text-align: left;
  }

  .form-message--success {
    border: 1px solid color-mix(in srgb, var(--color-accent) 24%, var(--color-border));
    background: color-mix(in srgb, var(--color-accent) 8%, var(--color-bg-card));
  }

  .form-message--error {
    border: 1px solid color-mix(in srgb, var(--color-danger) 28%, var(--color-border));
    background: color-mix(in srgb, var(--color-danger) 8%, var(--color-bg-card));
  }

  @media (max-width: 640px) {
    .subscribe-form {
      flex-direction: column;
    }

    .submit-button {
      width: 100%;
    }
  }
</style>
