---
export const prerender = false;

import Base from "../layouts/Base.astro";
import {
  buildJsonLdGraph,
  siteOrganization,
  siteWebSite,
  webPageNode,
} from "../lib/seo";

const title = "Subscribe to VentureDex Weekly Startup Picks";
const description = "Get VentureDex startup picks, funding signals, and weekly editorial research delivered by email.";
const schema = buildJsonLdGraph([
  siteOrganization(Astro.site?.toString()),
  siteWebSite(Astro.site?.toString()),
  webPageNode({
    path: "/subscribe",
    title,
    description,
    siteUrl: Astro.site?.toString(),
  }),
]);
const pending = Astro.url.searchParams.get("pending") === "1"
  || Astro.url.searchParams.get("subscribed") === "1";
const confirmed = Astro.url.searchParams.get("confirmed") === "1";
const already = Astro.url.searchParams.get("already") === "1";
const error = Astro.url.searchParams.get("error");
const source = (Astro.url.searchParams.get("source") ?? "subscribe_page").trim().slice(0, 64)
  || "subscribe_page";
const errorMessage = error === "preferences"
  ? "Choose at least one newsletter."
  : error === "email"
    ? "Enter a valid email address."
    : error === "server"
      ? "Something went wrong. Please try again."
      : error === "unsubscribed"
        ? "This address is unsubscribed. Re-subscribe below to opt back in."
        : error === "expired"
          ? "That confirmation link expired (links last 48 hours). Subscribe again below to get a fresh one."
          : error === "confirm"
            ? "That confirmation link is invalid or expired. Subscribe again below."
            : "";
---

<Base title={title} description={description} schema={schema}>
  <div class="container subscribe-page">
    <h1>Stay in the loop.</h1>
    <p class="subtitle">
      Every week, we pick 5-7 startups worth your attention. With editorial commentary.
      No spam, no fluff, just the good stuff.
    </p>

    {confirmed ? (
      <div class="success-box" role="status">
        <h2>You're subscribed.</h2>
        <p>Your email is confirmed. Curated startup picks and weekly research will arrive after the next editorial window.</p>
      </div>
    ) : already ? (
      <div class="success-box" role="status">
        <h2>You're already subscribed.</h2>
        <p>This address is already confirmed for VentureDex — nothing else to do.</p>
      </div>
    ) : pending ? (
      <div class="success-box" role="status">
        <h2>Almost there — check your inbox.</h2>
        <p>We sent a confirmation link to your email. Click it to finish subscribing. You won't receive anything until you confirm.</p>
      </div>
    ) : (
      <form class="subscribe-form" action="/api/subscribe" method="POST">
        {errorMessage && <p class="form-error" role="alert">{errorMessage}</p>}
        <input type="hidden" name="newsletter_preferences" value="1" />
        <input type="hidden" name="source" value={source} />
        <label class="honeypot" aria-hidden="true">
          Company
          <input type="text" name="company" tabindex="-1" autocomplete="off" />
        </label>
        <input
          type="email"
          name="email"
          required
          placeholder="you@example.com"
          class="email-input"
          autocomplete="email"
        />
        <fieldset class="frequency-fieldset" aria-label="Newsletter frequency">
          <label>
            <input type="checkbox" name="daily" checked />
            <span>Daily additions</span>
          </label>
          <label>
            <input type="checkbox" name="weekly" checked />
            <span>Weekly research</span>
          </label>
        </fieldset>
        <button type="submit" class="submit-button">Subscribe</button>
      </form>
    )}

    <p class="note">Unsubscribe anytime. We respect your inbox.</p>
  </div>
</Base>

<style>
  .subscribe-page {
    max-width: 500px;
    padding: var(--space-16) var(--space-6);
    text-align: center;
  }

  .subscribe-page h1 {
    font-size: 2rem;
    margin-bottom: var(--space-3);
  }

  .subtitle {
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-8);
  }

  .subscribe-form {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    max-width: 400px;
    margin: 0 auto var(--space-4);
  }

  .form-error {
    flex: 1 1 100%;
    margin: 0;
    padding: var(--space-2) var(--space-3);
    border: 1px solid #FCA5A5;
    border-radius: var(--radius);
    background: #FEF2F2;
    color: #991B1B;
    font-size: 0.82rem;
    line-height: 1.45;
    text-align: left;
  }

  .honeypot {
    position: absolute;
    left: -10000px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .email-input {
    flex: 1;
    min-width: 220px;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-family: var(--font-body);
    font-size: 0.9rem;
    background: var(--color-bg-card);
    color: var(--color-text);
  }

  .email-input:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: -1px;
    border-color: transparent;
  }

  .submit-button {
    flex: 1 1 100%;
    padding: var(--space-3) var(--space-6);
    background: var(--color-text);
    color: var(--color-bg);
    border: none;
    border-radius: var(--radius);
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.9rem;
    cursor: pointer;
    transition: opacity 0.15s;
  }

  .submit-button:hover {
    opacity: 0.85;
  }

  .note {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  .frequency-fieldset {
    flex: 1 1 100%;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-2);
    border: 0;
    margin: var(--space-1) 0;
    padding: 0;
  }

  .frequency-fieldset label {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    min-height: 40px;
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg-card);
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  .frequency-fieldset input {
    accent-color: var(--color-accent);
  }

  .success-box {
    max-width: 400px;
    margin: 0 auto var(--space-4);
    padding: var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg-card);
    text-align: left;
  }

  .success-box h2 {
    font-size: 1.1rem;
    margin-bottom: var(--space-2);
  }

  .success-box p {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  @media (max-width: 640px) {
    .subscribe-form {
      flex-direction: column;
    }

    .email-input,
    .submit-button {
      width: 100%;
    }

    .frequency-fieldset {
      grid-template-columns: 1fr;
    }
  }
</style>
