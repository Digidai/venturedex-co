---
import BrandLogo from "./BrandLogo.astro";
import { getCompanyBrandAsset } from "../lib/brand-assets";
import type { FundingRound } from "../lib/types";

interface Props {
  rounds: FundingRound[];
}

const { rounds } = Astro.props;

const items = rounds
  .filter((round) => round.company_slug && (round.amount || round.stage))
  .map((round) => ({
    name: round.company_name,
    slug: round.company_slug!,
    logo: getCompanyBrandAsset(round.company_slug),
    amount: round.amount,
    stage: round.stage,
    date: new Date(`${round.date}T00:00:00`).toLocaleDateString("en-US", {
      month: "short",
      day: "numeric",
    }),
  }));

const doubled = [...items, ...items];
---

{items.length > 0 && (
  <div class="ticker-wrapper" aria-label="Recent funding news">
    <div class="ticker-track">
      {doubled.map((item) => (
        <a href={`/startups/${item.slug}`} class="ticker-item">
          <BrandLogo asset={item.logo} name={item.name} size={16} class="ticker-logo" />
          <span class="ticker-name">{item.name}</span>
          {item.amount && <span class="ticker-amount">{item.amount}</span>}
          {item.stage && <span class="ticker-stage">{item.stage}</span>}
          <span class="ticker-date">{item.date}</span>
        </a>
      ))}
    </div>
  </div>
)}

<style>
  .ticker-wrapper {
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg-card);
  }

  .ticker-track {
    display: flex;
    gap: var(--space-6);
    padding: var(--space-3) 0;
    animation: ticker-scroll 40s linear infinite;
    width: max-content;
  }

  .ticker-track:hover {
    animation-play-state: paused;
  }

  @keyframes ticker-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .ticker-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    white-space: nowrap;
    text-decoration: none;
    color: var(--color-text);
    font-size: 0.75rem;
    transition: color 0.15s;
  }

  .ticker-item:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .ticker-logo {
    opacity: 0.95;
  }

  .ticker-name {
    font-weight: 600;
  }

  .ticker-amount {
    color: var(--color-accent);
    font-weight: 500;
  }

  .ticker-stage,
  .ticker-date {
    color: var(--color-text-secondary);
  }

  .ticker-date {
    font-size: 0.7rem;
  }
</style>
