---
import {
  getBrandInitials,
  type BrandAsset,
} from "../lib/brand-assets";

interface Props {
  asset?: BrandAsset | null;
  name: string;
  size?: number;
  class?: string;
  loading?: "eager" | "lazy";
}

const {
  asset = null,
  name,
  size = 20,
  class: className = "",
  loading = "lazy",
} = Astro.props;

const shape = asset?.shape ?? "icon";
const tileBackground = asset?.tile_background === "dark" ? "dark" : "light";
const initials = getBrandInitials(name);
const style = `--brand-size:${size}px;`;
---

<span
  class:list={[
    "brand-mark",
    `brand-mark--${shape}`,
    `brand-mark--bg-${tileBackground}`,
    asset ? "brand-mark--asset" : "brand-mark--fallback",
    className,
  ]}
  style={style}
  aria-hidden="true"
>
  {asset ? (
    <img
      src={asset.local_path}
      alt=""
      loading={loading}
      decoding="async"
      class="brand-logo"
    />
  ) : (
    <span class="brand-fallback">{initials}</span>
  )}
</span>

<style>
  .brand-mark {
    --brand-tile-bg: linear-gradient(135deg, #ffffff 0%, #f1f1ee 100%);
    --brand-tile-border: rgba(0, 0, 0, 0.1);
    --brand-logo-filter:
      drop-shadow(0 0 0.7px rgba(0, 0, 0, 0.8))
      drop-shadow(0 0.5px 1px rgba(0, 0, 0, 0.18));
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--brand-size);
    height: var(--brand-size);
    border: 1px solid var(--brand-tile-border);
    border-radius: max(6px, calc(var(--brand-size) * 0.18));
    background: var(--brand-tile-bg);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.85),
      0 1px 2px rgba(0, 0, 0, 0.04);
    overflow: hidden;
    vertical-align: middle;
  }

  .brand-logo {
    display: block;
    width: 76%;
    height: 76%;
    object-fit: contain;
    object-position: center;
    filter: var(--brand-logo-filter);
  }

  .brand-mark--wordmark .brand-logo {
    width: 86%;
    height: 54%;
  }

  .brand-fallback {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    color: var(--color-badge-text);
    font-size: calc(var(--brand-size) * 0.48);
    font-weight: 700;
    line-height: 1;
  }

  .brand-mark--fallback {
    --brand-tile-bg: var(--color-badge-bg);
    --brand-tile-border: var(--color-border);
    box-shadow: none;
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .brand-mark {
      --brand-tile-bg: linear-gradient(135deg, #ffffff 0%, #e8e8e3 100%);
      --brand-tile-border: rgba(255, 255, 255, 0.14);
      --brand-logo-filter:
        drop-shadow(0 0 0.8px rgba(0, 0, 0, 0.9))
        drop-shadow(0 0.5px 1px rgba(0, 0, 0, 0.24));
    }

    :root:not([data-theme="light"]) .brand-mark--fallback {
      --brand-tile-bg: var(--color-badge-bg);
      --brand-tile-border: var(--color-border);
    }
  }

  :root[data-theme="dark"] .brand-mark {
    --brand-tile-bg: linear-gradient(135deg, #ffffff 0%, #e8e8e3 100%);
    --brand-tile-border: rgba(255, 255, 255, 0.14);
    --brand-logo-filter:
      drop-shadow(0 0 0.8px rgba(0, 0, 0, 0.9))
      drop-shadow(0 0.5px 1px rgba(0, 0, 0, 0.24));
  }

  :root[data-theme="dark"] .brand-mark--fallback {
    --brand-tile-bg: var(--color-badge-bg);
    --brand-tile-border: var(--color-border);
  }

  .brand-mark.brand-mark--bg-dark,
  :root[data-theme="dark"] .brand-mark.brand-mark--bg-dark {
    --brand-tile-bg: linear-gradient(135deg, #171717 0%, #2a2a26 100%);
    --brand-tile-border: rgba(0, 0, 0, 0.22);
    --brand-logo-filter:
      drop-shadow(0 0 0.6px rgba(255, 255, 255, 0.35))
      drop-shadow(0 0.5px 1px rgba(0, 0, 0, 0.22));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 1px 2px rgba(0, 0, 0, 0.08);
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .brand-mark.brand-mark--bg-dark {
      --brand-tile-bg: linear-gradient(135deg, #171717 0%, #2a2a26 100%);
      --brand-tile-border: rgba(255, 255, 255, 0.14);
      --brand-logo-filter:
        drop-shadow(0 0 0.6px rgba(255, 255, 255, 0.35))
        drop-shadow(0 0.5px 1px rgba(0, 0, 0, 0.22));
    }
  }
</style>
