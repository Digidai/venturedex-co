---
import {
  getBrandInitials,
  type BrandAsset,
} from "../lib/brand-assets";

interface Props {
  asset?: BrandAsset | null;
  name: string;
  size?: number;
  class?: string;
  loading?: "eager" | "lazy";
}

const {
  asset = null,
  name,
  size = 20,
  class: className = "",
  loading = "lazy",
} = Astro.props;

const shape = asset?.shape ?? "icon";
const tileBackground = asset?.tile_background === "dark" ? "dark" : "light";
const initials = getBrandInitials(name);
const style = `--brand-size:${size}px;`;
---

<span
  class:list={[
    "brand-mark",
    `brand-mark--${shape}`,
    `brand-mark--bg-${tileBackground}`,
    asset ? "brand-mark--asset" : "brand-mark--fallback",
    className,
  ]}
  style={style}
  aria-hidden="true"
>
  {asset ? (
    <img
      src={asset.local_path}
      alt=""
      loading={loading}
      decoding="async"
      class="brand-logo"
    />
  ) : (
    <span class="brand-fallback">{initials}</span>
  )}
</span>

<style>
  .brand-mark {
    --brand-tile-bg: transparent;
    --brand-tile-border: transparent;
    --brand-logo-filter: none;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--brand-size);
    height: var(--brand-size);
    border: 1px solid var(--brand-tile-border);
    border-radius: max(4px, calc(var(--brand-size) * 0.18));
    background: var(--brand-tile-bg);
    box-shadow: none;
    overflow: hidden;
    vertical-align: middle;
  }

  .brand-logo {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    filter: var(--brand-logo-filter);
  }

  .brand-mark--wordmark .brand-logo {
    width: 86%;
    height: 54%;
  }

  .brand-fallback {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    color: var(--color-badge-text);
    font-size: calc(var(--brand-size) * 0.48);
    font-weight: 700;
    line-height: 1;
  }

  .brand-mark--fallback {
    --brand-tile-bg: var(--color-badge-bg);
    --brand-tile-border: var(--color-border);
    box-shadow: none;
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .brand-mark--fallback {
      --brand-tile-bg: var(--color-badge-bg);
      --brand-tile-border: var(--color-border);
    }
  }

  :root[data-theme="dark"] .brand-mark--fallback {
    --brand-tile-bg: var(--color-badge-bg);
    --brand-tile-border: var(--color-border);
  }

  .brand-mark.brand-mark--bg-dark,
  :root[data-theme="dark"] .brand-mark.brand-mark--bg-dark {
    --brand-tile-bg: #181818;
    --brand-tile-border: transparent;
    --brand-logo-filter:
      drop-shadow(0 0 0.5px rgba(255, 255, 255, 0.28))
      drop-shadow(0 0.5px 1px rgba(0, 0, 0, 0.16));
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .brand-mark.brand-mark--bg-dark {
      --brand-tile-bg: #181818;
      --brand-tile-border: transparent;
      --brand-logo-filter:
        drop-shadow(0 0 0.5px rgba(255, 255, 255, 0.28))
        drop-shadow(0 0.5px 1px rgba(0, 0, 0, 0.16));
    }
  }
</style>
