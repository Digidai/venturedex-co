---
import {
  getBrandInitials,
  type BrandAsset,
} from "../lib/brand-assets";

interface Props {
  asset?: BrandAsset | null;
  name: string;
  size?: number;
  class?: string;
  loading?: "eager" | "lazy";
}

const {
  asset = null,
  name,
  size = 20,
  class: className = "",
  loading = "lazy",
} = Astro.props;

const shape = asset?.shape === "wordmark" ? "wordmark" : "icon";
const tone = asset?.tone === "dark" || asset?.tone === "light" ? asset.tone : "auto";
const initials = getBrandInitials(name);
const tileBg = asset?.tile_bg;
const logoScale = typeof asset?.logo_scale === "number" && asset.logo_scale > 0
  ? Math.min(Math.max(asset.logo_scale, 0.55), 1.12)
  : null;
const style = [
  `--brand-size:${size}px`,
  tileBg ? `--brand-tile-bg:${tileBg}` : null,
  logoScale ? `--brand-logo-scale:${logoScale}` : null,
].filter(Boolean).join(";") + ";";
---

<span
  class:list={[
    "brand-mark",
    `brand-mark--${shape}`,
    `brand-mark--tone-${tone}`,
    asset ? "brand-mark--asset" : "brand-mark--fallback",
    className,
  ]}
  style={style}
  aria-hidden="true"
>
  {asset ? (
    <img
      src={asset.local_path}
      alt=""
      width={size}
      height={size}
      loading={loading}
      decoding="async"
      class="brand-logo"
    />
  ) : (
    <span class="brand-fallback">{initials}</span>
  )}
</span>

<style>
  .brand-mark {
    --brand-tile-bg: linear-gradient(135deg, #ffffff 0%, #f1f1ee 100%);
    --brand-tile-border: rgba(0, 0, 0, 0.1);
    --brand-logo-scale: 0.8;
    --brand-logo-filter:
      drop-shadow(0 0 0.7px rgba(0, 0, 0, 0.8))
      drop-shadow(0 0.5px 1px rgba(0, 0, 0, 0.18));
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--brand-size);
    min-width: var(--brand-size);
    height: var(--brand-size);
    aspect-ratio: 1;
    border: 1px solid var(--brand-tile-border);
    border-radius: max(6px, calc(var(--brand-size) * 0.18));
    background: var(--brand-tile-bg);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.85),
      0 1px 2px rgba(0, 0, 0, 0.04);
    overflow: hidden;
    vertical-align: middle;
  }

  .brand-logo {
    flex: 0 0 auto;
    display: block;
    width: calc(var(--brand-logo-scale) * 100%);
    height: calc(var(--brand-logo-scale) * 100%);
    object-fit: contain;
    object-position: center;
    filter: var(--brand-logo-filter);
    image-rendering: auto;
  }

  .brand-mark--wordmark .brand-logo {
    width: 88%;
    height: 54%;
  }

  .brand-mark--tone-dark {
    --brand-tile-bg: #111111;
    --brand-tile-border: rgba(255, 255, 255, 0.16);
    --brand-logo-filter: none;
  }

  .brand-mark--tone-light {
    --brand-tile-bg: #ffffff;
    --brand-logo-filter: none;
  }

  .brand-fallback {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    color: var(--color-badge-text);
    font-size: calc(var(--brand-size) * 0.48);
    font-weight: 700;
    line-height: 1;
  }

  .brand-mark--fallback {
    --brand-tile-bg: var(--color-badge-bg);
    --brand-tile-border: var(--color-border);
    box-shadow: none;
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .brand-mark {
      --brand-tile-bg: linear-gradient(135deg, #ffffff 0%, #e8e8e3 100%);
      --brand-tile-border: rgba(255, 255, 255, 0.14);
      --brand-logo-filter:
        drop-shadow(0 0 0.8px rgba(0, 0, 0, 0.9))
        drop-shadow(0 0.5px 1px rgba(0, 0, 0, 0.24));
    }

    :root:not([data-theme="light"]) .brand-mark--fallback {
      --brand-tile-bg: var(--color-badge-bg);
      --brand-tile-border: var(--color-border);
    }
  }

  :root[data-theme="dark"] .brand-mark {
    --brand-tile-bg: linear-gradient(135deg, #ffffff 0%, #e8e8e3 100%);
    --brand-tile-border: rgba(255, 255, 255, 0.14);
    --brand-logo-filter:
      drop-shadow(0 0 0.8px rgba(0, 0, 0, 0.9))
      drop-shadow(0 0.5px 1px rgba(0, 0, 0, 0.24));
  }

  :root[data-theme="dark"] .brand-mark--fallback {
    --brand-tile-bg: var(--color-badge-bg);
    --brand-tile-border: var(--color-border);
  }
</style>
