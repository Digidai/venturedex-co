---
import type { Site } from "../lib/types";

interface Props {
  site: Site;
}

const { site } = Astro.props;
const screenshotUrl = site.screenshot_r2_key ? `/screenshots/${site.screenshot_r2_key}` : null;
---

<article class="site-card">
  <a href={`/sites/${site.slug}`} class="card-link">
    <div class="card-screenshot">
      {screenshotUrl ? (
        <img src={screenshotUrl} alt={`${site.product_name} screenshot`} loading="lazy" />
      ) : (
        <div class="card-placeholder">
          <span>{site.product_name.charAt(0)}</span>
        </div>
      )}
    </div>
    <div class="card-body">
      <h3 class="card-name">{site.product_name}</h3>
      <p class="card-domain">{site.domain}</p>
      {site.summary && <p class="card-summary">{site.summary}</p>}
      <div class="card-meta">
        {site.why_featured && (
          <span class="badge badge-featured">{site.why_featured}</span>
        )}
        {site.product_type && (
          <span class="badge">{site.product_type}</span>
        )}
      </div>
    </div>
  </a>
</article>

<style>
  .site-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--color-bg-card);
    transition: border-color 0.15s;
    max-width: 420px;
  }

  .site-card:hover {
    border-color: var(--color-accent);
  }

  .card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .card-screenshot {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--color-badge-bg);
  }

  .card-screenshot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: 2rem;
    color: var(--color-text-secondary);
  }

  .card-body {
    padding: var(--space-4);
  }

  .card-name {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: var(--space-1);
  }

  .card-domain {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-2);
  }

  .card-summary {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    line-height: 1.4;
    margin-bottom: var(--space-3);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .badge {
    font-size: 0.7rem;
    font-weight: 500;
    padding: 2px 8px;
    border-radius: 99px;
    background: var(--color-badge-bg);
    color: var(--color-badge-text);
  }

  .badge-featured {
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    color: var(--color-accent);
  }
</style>
